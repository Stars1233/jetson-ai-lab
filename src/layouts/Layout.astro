---

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "The NVIDIA Jetson AI Lab is your guide to running generative AI models entirely on-device with NVIDIA Jetson. Explore optimized tutorials, benchmarks and hands-on examples for LLMs, VLMs, VLAs, speech recognition, and more.", image = "/images/hero/nvidia-logo.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/icons/nvidia-logo.png" />
    <link rel="apple-touch-icon" href="/images/icons/nvidia-logo.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Jetson AI Lab</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Jetson AI Lab`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content="Jetson AI Lab" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Jetson AI Lab`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SXH8S4Y8RW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SXH8S4Y8RW');
    </script>

    <!-- ISO download tracking -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        const links = Array.from(document.querySelectorAll('a[href$=".iso"]'));

        links.forEach(link => {
          link.addEventListener('click', function (e) {
            const url = link.href;
            const openInNewTab = e.metaKey || e.ctrlKey || link.target === '_blank';
            const fileName = (new URL(url)).pathname.split('/').pop() || 'unknown';
            if (!openInNewTab) e.preventDefault();

            // Optional: parse your NVIDIA URL for useful params
            const m = link.pathname.match(/L4T\/(r\d+_Release_v[\d.]+)\/.*jetsoninstaller-([\d.]+)-(r[\d.]+)-([\d-]+)-(arm64)\.iso$/);

            if (typeof gtag === 'function') {
              gtag('event', 'download_iso_file', {
                file_extension: 'iso',
                file_name: fileName,
                link_url: url,
                l4t_release_raw: m?.[1] || '',
                installer_version: m?.[2] || '',
                l4t_release: m?.[3] || '',
                build_timestamp: m?.[4] || '',
                arch: m?.[5] || '',
                event_callback: function () { if (!openInNewTab) window.location.href = url; },
                event_timeout: 2000
              });
            }

            if (!openInNewTab) setTimeout(() => { window.location.href = url; }, 1000);
          }, { capture: true });
        });
      });
    </script>

    <!-- OneTrust Cookies Consent Notice - Only on Production -->
    <!-- Excluded on localhost/staging to avoid popup loop on non-production domains -->
    <script is:inline>
      // Only load OneTrust on production domain
      if (window.location.hostname === 'www.jetson-ai-lab.com' || window.location.hostname === 'jetson-ai-lab.com') {
        // OneTrust Cookie Consent
        var script1 = document.createElement('script');
        script1.src = 'https://cdn.cookielaw.org/scripttemplates/otSDKStub.js';
        script1.type = 'text/javascript';
        script1.charset = 'UTF-8';
        script1.setAttribute('data-domain-script', '018e2d65-efdf-7071-b793-f15ccf25c234');
        document.head.appendChild(script1);

        // OptanonWrapper callback
        window.OptanonWrapper = function() {
          var event = new Event('bannerLoaded');
          window.dispatchEvent(event);
        };

        // OneTrust custom JS
        var script2 = document.createElement('script');
        script2.src = 'https://images.nvidia.com/aem-dam/Solutions/ot-js/ot-custom.js';
        script2.type = 'text/javascript';
        document.head.appendChild(script2);

        // Adobe DTM
        var script3 = document.createElement('script');
        script3.src = '//assets.adobedtm.com/5d4962a43b79/814eb6e9b4e1/launch-4bc07f1e0b0b.min.js';
        document.head.appendChild(script3);
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-nvidia-white text-nvidia-black">
    <!-- Migration Notice Banner -->
    <div id="migration-notice" class="bg-gradient-to-r from-nvidia-green to-gray-100 text-black px-4 py-3 shadow-lg" style="display: none;">
      <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 flex-1">
          <span class="text-2xl">🎉</span>
          <div class="flex-1">
            <p class="font-semibold">Welcome to Jetson AI Lab 2.0!</p>
            <p class="text-sm">We've redesigned the site with curated tutorials. Looking for old content?
              <a href="/archive/index.html" class="underline font-medium hover:text-white">Browse the archive →</a>
            </p>
          </div>
        </div>
        <button id="dismiss-notice" class="text-black hover:text-white font-bold text-xl px-2 py-1 rounded hover:bg-black/10 transition-colors" aria-label="Dismiss">
          ×
        </button>
      </div>
    </div>

    <header class="bg-nvidia-white border-b border-nvidia-gray-200 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <a href="/" class="flex items-center">
              <span class="text-2xl font-nvidia font-bold text-nvidia-black">Jetson AI Lab</span>
            </a>
          </div>
          <div class="hidden md:flex items-center space-x-1">
            <a href="/" class="text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200">Home</a>
            <a href="/models" class="text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200">Models</a>
            <a href="/tutorials" class="text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200">Tutorials</a>
            <a href="/community" class="text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200">Projects</a>
            <a href="/research" class="text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-2 text-sm font-medium rounded-md transition-colors duration-200">Research Group</a>
          </div>
          <div class="md:hidden flex items-center">
            <button id="mobile-menu-button" class="text-nvidia-black hover:text-nvidia-green p-2" aria-label="Toggle menu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
        <!-- Mobile menu, hidden by default -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <a href="/" class="block text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-3 text-base font-medium rounded-md transition-colors duration-200">Home</a>
          <a href="/models" class="block text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-3 text-base font-medium rounded-md transition-colors duration-200">Models</a>
          <a href="/tutorials" class="block text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-3 text-base font-medium rounded-md transition-colors duration-200">Tutorials</a>
          <a href="/community" class="block text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-3 text-base font-medium rounded-md transition-colors duration-200">Projects</a>
          <a href="/research" class="block text-nvidia-black hover:text-nvidia-green hover:bg-nvidia-gray-50 px-4 py-3 text-base font-medium rounded-md transition-colors duration-200">Research Group</a>
        </div>
      </nav>
    </header>

    <!-- Mobile Menu Toggle Script -->
    <script is:inline>
      (function() {
        var menuButton = document.getElementById('mobile-menu-button');
        var mobileMenu = document.getElementById('mobile-menu');

        if (menuButton && mobileMenu) {
          menuButton.addEventListener('click', function() {
            mobileMenu.classList.toggle('hidden');
          });
        }
      })();
    </script>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="bg-nvidia-black text-nvidia-white">
      <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center mb-6">
              <span class="text-2xl font-nvidia font-bold">Jetson AI Lab</span>
            </div>
            <p class="text-nvidia-gray-300 mb-6 text-lg leading-relaxed">
              Experience the latest generative AI models optimized for Jetson.
              Run locally, without depending on the cloud.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-nvidia-gray-300 tracking-wider uppercase mb-6">Resources</h3>
            <ul class="space-y-3">
              <li><a href="/models" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">Models</a></li>
              <li><a href="/tutorials" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">Tutorials</a></li>
              <li><a href="/community" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">Projects</a></li>
              <li><a href="/research" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">Research Group</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-nvidia-gray-300 tracking-wider uppercase mb-6">NVIDIA</h3>
            <ul class="space-y-3">
              <li><a href="https://developer.nvidia.com" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">Developer Portal</a></li>
              <li><a href="https://www.nvidia.com" class="text-nvidia-gray-300 hover:text-nvidia-white transition-colors duration-200">NVIDIA.com</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-nvidia-gray-700">
          <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-nvidia-gray-400 mb-4">
            <li><a href="https://www.nvidia.com/en-us/about-nvidia/privacy-policy/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Privacy Policy</a></li>
            <li><a href="https://www.nvidia.com/en-us/about-nvidia/privacy-center/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Your Privacy Choices</a></li>
            <li><a href="https://www.nvidia.com/en-us/about-nvidia/legal-info/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Legal</a></li>
            <li><a href="https://www.nvidia.com/en-us/about-nvidia/accessibility/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Accessibility</a></li>
            <li><a href="https://www.nvidia.com/en-us/about-nvidia/company-policies/" target="_self" class="hover:text-nvidia-white transition-colors duration-200">Corporate Policies</a></li>
            <li><a href="https://www.nvidia.com/en-us/product-security/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Product Security</a></li>
            <li><a href="https://www.nvidia.com/en-us/contact/" target="_blank" class="hover:text-nvidia-white transition-colors duration-200">Contact</a></li>
          </ul>
          <p class="text-nvidia-gray-400 text-sm text-center">
            © 2026 NVIDIA Corporation. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      import { trackCopyInferenceCommand } from '../lib/analyticsInference';
      import {
        readInferenceBrowserPrefs,
        writeInferenceBrowserPrefsPatch,
        clearVllmFieldsInInferenceBrowserPrefs,
        normalizeInferenceEngineKey,
      } from '../lib/inferenceBrowserPrefs';
      import {
        applyMatrixModuleTabDisabledVisual,
        clearMatrixModuleTabDisabledVisual,
        syncMatrixEngineRailSelection,
        syncMatrixModuleTabSelection,
      } from '../lib/matrixUiSync';

      (function () {
        function qs(root, sel) { return root.querySelector(sel); }
        function qsa(root, sel) { return Array.from(root.querySelectorAll(sel)); }
        function sanitize(name) { return (name || '').toLowerCase().replace(/[^a-z0-9\-]/g, '-'); }
        function baseMounts() {
          return [
            '-v $HOME/.cache/huggingface:/root/.cache/huggingface',
            '-v /mnt/nvme/cache:/cache'
          ].join(' \\\n  ');
        }

        // Default engine images fallback
        var defaultEngineImages = {
          ollama: 'ollama/ollama:latest',
          vllm: 'ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin',
          llamacpp: 'ghcr.io/ggerganov/llama.cpp:server',
          tensorrtllm: 'nvcr.io/nvidia/tensorrt-llm:latest',
          diffusers: 'pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime',
          comfyui: 'ghcr.io/comfyanonymous/comfyui:latest',
          whispercpp: 'ghcr.io/ggerganov/whisper.cpp:latest',
          riva: 'nvcr.io/nvidia/riva/riva-speech:latest'
        };

        function getEngineImage(meta, engine, device) {
          // Determine if Thor or Orin based on device selection
          var isThor = device && device.toLowerCase().includes('thor');

          // Try device-specific images first
          if (isThor && meta.engineImagesThor && meta.engineImagesThor[engine]) {
            return meta.engineImagesThor[engine];
          }
          if (!isThor && meta.engineImagesOrin && meta.engineImagesOrin[engine]) {
            return meta.engineImagesOrin[engine];
          }

          // Fallback to legacy engineImages
          if (meta.engineImages && meta.engineImages[engine]) {
            return meta.engineImages[engine];
          }
          return defaultEngineImages[engine] || 'ubuntu:22.04';
        }

        function highlightSyntax(txt, lang) {
          // Simple syntax highlighting for shell/bash commands
          if (lang === 'shell' || lang === 'bash') {
            return txt
              .split('\n')
              .map(function(line) {
                // Comments
                if (line.trim().startsWith('#')) {
                  return '<span class="text-slate-500">' + escapeHtml(line) + '</span>';
                }
                // Highlight commands and keywords
                var highlighted = escapeHtml(line)
                  // Commands at start of line or after pipe/semicolon
                  .replace(/^(sudo|docker|ollama|vllm|python|curl|git|bash|wget|chmod|chown|cd|mkdir|rm|cp|mv|cat|echo|export|source|pip|npm|jetson-containers|trtllm-run|riva_start)(\s)/g,
                    '<span class="text-cyan-400">$1</span>$2')
                  // Docker/command flags
                  .replace(/(\s)(--?[\w-]+)/g, '$1<span class="text-emerald-400">$2</span>')
                  // URLs and paths
                  .replace(/(https?:\/\/[^\s]+)/g, '<span class="text-amber-400">$1</span>')
                  // Environment variables
                  .replace(/(\$\w+|\$\{[^}]+\})/g, '<span class="text-purple-400">$1</span>');
                return highlighted;
              })
              .join('\n');
          }
          // Python highlighting
          if (lang === 'python') {
            return txt
              .split('\n')
              .map(function(line) {
                if (line.trim().startsWith('#')) {
                  return '<span class="text-slate-500">' + escapeHtml(line) + '</span>';
                }
                var highlighted = escapeHtml(line)
                  .replace(/\b(import|from|def|class|return|if|else|elif|try|except|for|while|in|as|with|True|False|None)\b/g,
                    '<span class="text-purple-400">$1</span>')
                  .replace(/\b(print|requests|json)\b/g, '<span class="text-cyan-400">$1</span>')
                  .replace(/(["'][^"']*["'])/g, '<span class="text-emerald-400">$1</span>');
                return highlighted;
              })
              .join('\n');
          }
          // YAML/Compose highlighting
          if (lang === 'yaml') {
            return txt
              .split('\n')
              .map(function(line) {
                if (line.trim().startsWith('#')) {
                  return '<span class="text-slate-500">' + escapeHtml(line) + '</span>';
                }
                var highlighted = escapeHtml(line)
                  .replace(/^(\s*)([\w_-]+)(:)/gm, '$1<span class="text-cyan-400">$2</span>$3')
                  .replace(/(["'][^"']*["'])/g, '<span class="text-emerald-400">$1</span>');
                return highlighted;
              })
              .join('\n');
          }
          return escapeHtml(txt);
        }

        function escapeHtml(text) {
          var div = document.createElement('div');
          div.textContent = text;
          return div.innerHTML;
        }

        function buildVllmCommand(meta, st) {
          // Check for custom run command from supportedEngines
          if (meta.supportedEngines && meta.supportedEngines.length > 0) {
            var vllmEngine = meta.supportedEngines.find(function(e) {
              return e.engine && e.engine.toLowerCase() === 'vllm';
            });
            if (vllmEngine) {
              var customCmd = null;
              var device = st.device || 'Jetson Orin';
              if (device === 'Jetson Thor' && (vllmEngine.serve_command_thor || vllmEngine.run_command_thor)) {
                customCmd = vllmEngine.serve_command_thor || vllmEngine.run_command_thor;
              } else if (device === 'Jetson Orin' && (vllmEngine.serve_command_orin || vllmEngine.run_command_orin)) {
                customCmd = vllmEngine.serve_command_orin || vllmEngine.run_command_orin;
              } else if (vllmEngine.run_command) {
                customCmd = vllmEngine.run_command;
              }
              if (customCmd) {
                // Return just the vllm serve part (after the docker run command)
                var vllmIndex = customCmd.indexOf('vllm serve');
                if (vllmIndex !== -1) {
                  return customCmd.substring(vllmIndex);
                }
                return customCmd;
              }
            }
          }

          // Fallback to generic command
          var model = meta.hfCheckpoint || 'model/checkpoint';
          var parts = ['vllm serve ' + model];

          // Always include --trust-remote-code
          parts.push('--trust-remote-code');

          // Add optional parameters if provided
          if (st.vllmPort) {
            parts.push('--port ' + st.vllmPort);
          }
          if (st.vllmMaxModelLen) {
            parts.push('--max-model-len ' + st.vllmMaxModelLen);
          }
          if (st.vllmGpuMem) {
            parts.push('--gpu-memory-utilization ' + st.vllmGpuMem);
          }

          // Format with line continuations for readability
          if (parts.length > 2) {
            return parts.join(' \\\n    ');
          }
          return parts.join(' ');
        }

        function engineRunLine(engine, modelId, port, ctx, batch, steps, meta, st) {
          var m = sanitize(modelId);
          var engineLower = (engine || '').toLowerCase();
          switch (engineLower) {
            case 'ollama': return 'ollama run ' + m;
            case 'vllm': return buildVllmCommand(meta, st || {});
            case 'llamacpp': return './server -m /models/' + m + '.gguf -c ' + ctx + ' -b ' + batch + ' --port ' + port;
            case 'tensorrtllm': return 'trtllm-run --engine-dir /engines/' + m + ' --max-batch-size ' + batch + ' --http-port ' + port;
            case 'diffusers': return 'python run_' + m + '.py --output /outputs --steps ' + (steps || 25);
            case 'comfyui': return 'python main.py --listen --port ' + port;
            case 'whispercpp': return './main -m /models/ggml-base.en.bin -f sample.wav';
            case 'riva': return 'riva_start.sh && riva_start_client.sh';
            default: return 'echo "Run ' + m + '"';
          }
        }

        function applyHfToken(cmd, st) {
          if (!cmd || !st.hfToken) return cmd;
          cmd = cmd.replace(/\\\$HF_TOKEN/g, st.hfToken);
          cmd = cmd.replace(/\$\{HF_TOKEN\}/g, st.hfToken);
          cmd = cmd.replace(/\$HF_TOKEN/g, st.hfToken);
          return cmd;
        }

        function applyVllmOverrides(cmd, st) {
          if (!cmd || !cmd.includes('vllm serve')) return cmd;
          var flags = [
            { key: 'vllmPort', flag: '--port', defaultVal: null },
            { key: 'vllmMaxModelLen', flag: '--max-model-len', defaultVal: null },
            { key: 'vllmGpuMem', flag: '--gpu-memory-utilization', defaultVal: '0.8' }
          ];
          for (var i = 0; i < flags.length; i++) {
            var val = st[flags[i].key] || flags[i].defaultVal;
            if (!val) continue;
            var flag = flags[i].flag;
            var regex = new RegExp(flag.replace(/[-]/g, '[-]') + '\\s+\\S+');
            if (regex.test(cmd)) {
              if (!cmd.match(new RegExp(flag.replace(/[-]/g, '[-]') + '\\s+\\$'))) {
                cmd = cmd.replace(regex, flag + ' ' + val);
              }
            } else {
              var serveIdx = cmd.indexOf('vllm serve');
              var afterServe = cmd.indexOf(' ', serveIdx + 'vllm serve '.length);
              if (afterServe === -1) afterServe = cmd.length;
              cmd = cmd.slice(0, afterServe) + ' ' + flag + ' ' + val + cmd.slice(afterServe);
            }
          }
          return cmd;
        }

        function buildShell(meta, st) {
          var engineLower = (st.engine || '').toLowerCase();

          if (meta.useEvalMatrix && meta.evalSnippetByModule && st.activeModule && st.tab === 'shell') {
            var er = meta.evalSnippetByModule[st.activeModule];
            if (er && er.shell) return er.shell;
            return '# No shell snippet for this module.';
          }

          if (meta.useMatrix && meta.moduleCommandMatrix && st.activeModule) {
            var row = meta.moduleCommandMatrix[st.activeModule];
            if (row) {
              var base = row[st.engine] || row[engineLower];
              if (!base) {
                var normEng = engineLower.replace(/[.\-_]/g, '');
                for (var rk in row) {
                  if (Object.prototype.hasOwnProperty.call(row, rk) && rk.replace(/[.\-_]/g, '') === normEng) {
                    base = row[rk];
                    break;
                  }
                }
              }
              if (base) {
                var cmd = base;
                if (engineLower === 'vllm') cmd = applyVllmOverrides(cmd, st);
                cmd = applyHfToken(cmd, st);
                return cmd;
              }
            }
          }

          // Check for full custom command from supportedEngines (for vLLM and llama.cpp)
          if (meta.supportedEngines && meta.supportedEngines.length > 0) {
            var customEngine = meta.supportedEngines.find(function(e) {
              if (!e.engine) return false;
              var engineName = e.engine.toLowerCase();
              var normalizedName = engineName.replace(/[.\-_]/g, '');
              var normalizedEngineLower = engineLower.replace(/[.\-_]/g, '');
              return engineName === engineLower || normalizedName === normalizedEngineLower;
            });
            if (customEngine) {
              var customCmd = null;
              var device = st.device || 'Jetson Orin';
              if (device === 'Jetson Thor' && (customEngine.serve_command_thor || customEngine.run_command_thor)) {
                customCmd = customEngine.serve_command_thor || customEngine.run_command_thor;
              } else if (device === 'Jetson Orin' && (customEngine.serve_command_orin || customEngine.run_command_orin)) {
                customCmd = customEngine.serve_command_orin || customEngine.run_command_orin;
              } else if (customEngine.run_command) {
                customCmd = customEngine.run_command;
              }
              if (customCmd) {
                if (engineLower === 'vllm') {
                  customCmd = applyVllmOverrides(customCmd, st);
                }
                customCmd = applyHfToken(customCmd, st);
                var installCmd = null;
                var device = st.device || 'Jetson Orin';
                if (device === 'Jetson Thor' && customEngine.install_command_thor) {
                  installCmd = customEngine.install_command_thor;
                } else if (device === 'Jetson Orin' && customEngine.install_command_orin) {
                  installCmd = customEngine.install_command_orin;
                } else if (customEngine.install_command) {
                  installCmd = customEngine.install_command;
                }
                if (installCmd) {
                  return '# Setup\n' + installCmd + '\n\n# Run\n' + customCmd;
                }
                return customCmd;
              }
            }
          }

          var image = getEngineImage(meta, engineLower, st.device);
          var container = sanitize(st.engine) + '-' + sanitize(meta.modelId);
          var runLine = engineRunLine(engineLower, meta.modelId, st.port, st.ctx, st.batch, st.steps, meta, st);

          if (engineLower === 'ollama') {
              return runLine;
          }

          // For vLLM with multiline command, format nicely
          if (engineLower === 'vllm' && runLine.includes('\\\n')) {
            return 'sudo docker run -it --rm --pull always \\\n    --runtime=nvidia --network host \\\n    ' + image + ' \\\n    ' + runLine;
          }

          return 'sudo docker run -it --rm --pull always --runtime=nvidia --network host ' + image + ' ' + runLine;
        }

        function buildCompose(meta, st) {
          var image = (meta.engineImages && meta.engineImages[st.engine]) || 'ubuntu:22.04';
          var service = sanitize(st.engine) + '-' + sanitize(meta.modelId);
          return [
            'services:',
            '  ' + service + ':',
            '    image: ' + image,
            '    container_name: ' + service,
            '    network_mode: "host"',
            '    deploy:',
            '      resources:',
            '        reservations:',
            '          devices:',
            '            - capabilities: ["gpu"]',
            '    environment:',
            '      - HF_HUB_ENABLE_HF_TRANSFER=1',
            '    volumes:',
            '      - $HOME/.cache/huggingface:/root/.cache/huggingface',
            '      - /mnt/nvme/cache:/cache',
            '    command: >-',
            '      ' + engineRunLine(st.engine, meta.modelId, st.port, st.ctx, st.batch, st.steps, meta)
          ].join('\n');
        }

        function buildPython(meta, st) {
          if (meta.useEvalMatrix && meta.evalSnippetByModule && st.activeModule && st.tab === 'python') {
            var erp = meta.evalSnippetByModule[st.activeModule];
            if (erp && erp.python) return erp.python;
            return '# No Python snippet for this module.';
          }
          var base = [
            'import requests',
            '',
            'URL = f"http://localhost:' + st.port + '/v1/chat/completions"',
            'payload = {"model": "local-model", "messages": [{"role":"user","content":"Hello Jetson"}]}',
            'try:',
            '    r = requests.post(URL, json=payload, timeout=60)',
            '    print(r.json())',
            'except Exception as e:',
            '    print("Request failed:", e)'
          ].join('\n');
          if (st.engine === 'diffusers' || st.engine === 'comfyui') {
            return ['# Example client for image generation servers', '# Replace with the API of the selected engine', base].join('\n');
          }
          return base;
        }

        function firstEnabledRunModuleId(meta) {
          var list = (meta && meta.modalVisibleModules) || [];
          for (var i = 0; i < list.length; i++) {
            if (!list[i].disabled) return list[i].id;
          }
          return list[0] && list[0].id;
        }

        function getState(modal, meta) {
          var id = meta.modelId || '';
          var checked = modal.querySelector('input[name="engine-' + id + '"]:checked');
          var engineSel = modal.querySelector('[data-engine]');
          var useMatrix = !!(meta.useMatrix && meta.modalVisibleModules && meta.modalVisibleModules.length);
          var useEvalMatrix = !!(meta.useEvalMatrix && meta.evalModalVisibleModules && meta.evalModalVisibleModules.length);

          // Get engine value with multiple fallbacks
          var engineVal = '';
          if (useMatrix) {
            engineVal = modal.getAttribute('data-active-engine') || meta.defaultEngineId || 'vllm';
          } else if (useEvalMatrix) {
            engineVal = 'eval';
          } else if (engineSel && engineSel.value) {
            engineVal = engineSel.value;
          } else if (checked && checked.value) {
            engineVal = checked.value;
          } else if (meta.defaultEngineId) {
            engineVal = meta.defaultEngineId;
          } else {
            engineVal = 'ollama'; // ultimate fallback
          }

          var deviceVal;
          if (useMatrix || useEvalMatrix) {
            var am = modal.getAttribute('data-active-module') || firstEnabledRunModuleId(meta);
            var plat = meta.moduleIdToPlatform && am ? meta.moduleIdToPlatform[am] : 'orin';
            deviceVal = plat === 'thor' ? 'Jetson Thor' : 'Jetson Orin';
          } else {
            deviceVal = qs(modal, '[data-device]') ? qs(modal, '[data-device]').value : undefined;
          }

          var activeModule = '';
          if (useMatrix || useEvalMatrix) {
            activeModule = modal.getAttribute('data-active-module') || firstEnabledRunModuleId(meta) || '';
          }

          // Get vLLM specific parameters (only if inputs exist and have values)
          var vllmPortEl = qs(modal, '[data-vllm-port]');
          var vllmMaxModelLenEl = qs(modal, '[data-vllm-max-model-len]');
          var vllmGpuMemEl = qs(modal, '[data-vllm-gpu-mem]');
          var hfTokenEl = qs(modal, '[data-hf-token]');

          return {
            engine: engineVal,
            activeModule: activeModule,
            device: deviceVal,
            jetpack: qs(modal, '[data-jetpack]') ? qs(modal, '[data-jetpack]').value : undefined,
            port: Number(qs(modal, '[data-port]') ? qs(modal, '[data-port]').value : 9000),
            batch: Number(qs(modal, '[data-batch]') ? qs(modal, '[data-batch]').value : 1),
            ctx: Number(qs(modal, '[data-ctx]') ? qs(modal, '[data-ctx]').value : 4096),
            steps: Number(qs(modal, '[data-steps]') ? qs(modal, '[data-steps]').value : 25),
            tab: modal.getAttribute('data-tab') || 'shell',
            vllmPort: vllmPortEl && vllmPortEl.value ? vllmPortEl.value : '',
            vllmMaxModelLen: vllmMaxModelLenEl && vllmMaxModelLenEl.value ? vllmMaxModelLenEl.value : '',
            vllmGpuMem: vllmGpuMemEl && vllmGpuMemEl.value ? vllmGpuMemEl.value : '',
            hfToken: hfTokenEl && hfTokenEl.value ? hfTokenEl.value.trim() : ''
          };
        }

        function updateVllmConfigVisibility(modal) {
          var engineSel = qs(modal, '[data-engine]');
          var vllmConfig = qs(modal, '[data-vllm-config]');
          var hfSection = qs(modal, '[data-hf-token-section]');
          var metaStr = modal.getAttribute('data-meta') || '{}';
          var meta = JSON.parse(metaStr);
          var useMatrix = !!(meta.useMatrix && meta.modalVisibleModules && meta.modalVisibleModules.length);
          var useEvalMatrix = !!(meta.useEvalMatrix && meta.evalModalVisibleModules && meta.evalModalVisibleModules.length);

          if (useEvalMatrix) {
            if (vllmConfig) vllmConfig.classList.add('hidden');
            if (hfSection) hfSection.classList.add('hidden');
            var advStripE = qs(modal, '[data-run-matrix-advanced-strip]');
            if (advStripE) advStripE.classList.add('hidden');
            return;
          }

          var engineVal = '';
          if (useMatrix) {
            engineVal = (modal.getAttribute('data-active-engine') || '').toLowerCase();
          } else if (engineSel) {
            engineVal = engineSel.value.toLowerCase();
          }
          if (vllmConfig) {
            if (engineVal === 'vllm') {
              vllmConfig.classList.remove('hidden');
            } else {
              vllmConfig.classList.add('hidden');
            }
          }

          if (hfSection) {
            var deviceVal = '';
            if (useMatrix || useEvalMatrix) {
              var am = modal.getAttribute('data-active-module') || firstEnabledRunModuleId(meta);
              var plat = meta.moduleIdToPlatform && am ? meta.moduleIdToPlatform[am] : 'orin';
              deviceVal = plat === 'thor' ? 'Jetson Thor' : 'Jetson Orin';
            } else {
              var deviceSel = qs(modal, '[data-device]');
              deviceVal = deviceSel ? deviceSel.value : '';
            }
            if (meta.needsHfToken && deviceVal === 'Jetson Thor' && !useEvalMatrix) {
              hfSection.classList.remove('hidden');
            } else {
              hfSection.classList.add('hidden');
            }
          }

          var hfVis = !!(hfSection && !hfSection.classList.contains('hidden'));
          var vllmVis = !!(vllmConfig && !vllmConfig.classList.contains('hidden'));
          var advStrip = qs(modal, '[data-run-matrix-advanced-strip]');
          if (advStrip) {
            advStrip.classList.toggle('hidden', !hfVis && !vllmVis);
          }
          var legacyAdv = qs(modal, '[data-run-legacy-advanced]');
          if (legacyAdv) {
            legacyAdv.classList.toggle('hidden', !hfVis && !vllmVis);
          }
        }

        function syncRunModalMatrixEngineRail(modal, meta) {
          if (!meta.useMatrix) return;
          var ae = modal.getAttribute('data-active-engine') || '';
          var aeNorm = normalizeInferenceEngineKey(ae);
          syncMatrixEngineRailSelection(
            modal.querySelectorAll('[data-run-engine-btn]'),
            function (btn) {
              return normalizeInferenceEngineKey(btn.getAttribute('data-run-engine-btn') || '') === aeNorm;
            },
            'run-modal',
          );
        }

        function updateRunModalModuleTabAvailability(modal, meta) {
          if (meta.useEvalMatrix) return;
          if (!meta.useMatrix) return;
          if (!meta.modalVisibleModules || !meta.modalVisibleModules.length) {
            syncRunModalMatrixEngineRail(modal, meta);
            return;
          }
          var activeEngine = modal.getAttribute('data-active-engine') || meta.defaultEngineId || '';
          var engineSupportMap = meta.modulesSupportedByEngine || {};
          var allowedForActiveEngine = null;
          if (Object.prototype.hasOwnProperty.call(engineSupportMap, activeEngine)) {
            allowedForActiveEngine = engineSupportMap[activeEngine];
          } else {
            for (var ek in engineSupportMap) {
              if (Object.prototype.hasOwnProperty.call(engineSupportMap, ek) && normalizeInferenceEngineKey(ek) === normalizeInferenceEngineKey(activeEngine)) {
                allowedForActiveEngine = engineSupportMap[ek];
                break;
              }
            }
          }
          function commandForModuleAndEngine(moduleId, engineName) {
            var commands = meta.moduleCommandMatrix && meta.moduleCommandMatrix[moduleId];
            if (!commands) return '';
            for (var ck in commands) {
              if (Object.prototype.hasOwnProperty.call(commands, ck) && normalizeInferenceEngineKey(ck) === normalizeInferenceEngineKey(engineName)) {
                return commands[ck] || '';
              }
            }
            return '';
          }
          modal.querySelectorAll('[data-run-module-tab]').forEach(function (btn) {
            var global = btn.getAttribute('data-run-module-global-disabled') === '1';
            var moduleId = btn.getAttribute('data-run-module-tab') || '';
            var unsupportedByEngine = false;
            if (allowedForActiveEngine != null && Array.isArray(allowedForActiveEngine)) {
              unsupportedByEngine = allowedForActiveEngine.length === 0 || allowedForActiveEngine.indexOf(moduleId) === -1;
            }
            var hasCmd = !!String(commandForModuleAndEngine(moduleId, activeEngine)).trim();
            var dis = global || unsupportedByEngine || !hasCmd;
            btn.disabled = dis;
            if (dis) {
              applyMatrixModuleTabDisabledVisual(btn);
            } else {
              clearMatrixModuleTabDisabledVisual(btn);
            }
          });
          var am = modal.getAttribute('data-active-module');
          var activeBtn = am && modal.querySelector('[data-run-module-tab="' + am + '"]');
          if (!activeBtn || activeBtn.disabled) {
            var firstOk = modal.querySelector('[data-run-module-tab]:not(:disabled)');
            if (firstOk) {
              modal.setAttribute('data-active-module', firstOk.getAttribute('data-run-module-tab') || '');
            }
          }
          var map = meta.modulesSupportedByEngine || {};
          var activeModule = modal.getAttribute('data-active-module') || '';
          modal.querySelectorAll('[data-run-engine-btn]').forEach(function (btn) {
            var engineName = btn.getAttribute('data-run-engine-btn') || '';
            var allowed = null;
            if (Object.prototype.hasOwnProperty.call(map, engineName)) allowed = map[engineName];
            else {
              for (var k in map) {
                if (Object.prototype.hasOwnProperty.call(map, k) && normalizeInferenceEngineKey(k) === normalizeInferenceEngineKey(engineName)) {
                  allowed = map[k];
                  break;
                }
              }
            }
            var dis = false;
            if (allowed != null && Array.isArray(allowed)) {
              if (allowed.length === 0) dis = true;
              else dis = allowed.indexOf(activeModule) === -1;
            }
            var key = null;
            var commands = meta.moduleCommandMatrix && meta.moduleCommandMatrix[activeModule];
            if (commands) {
              for (var ck in commands) {
                if (Object.prototype.hasOwnProperty.call(commands, ck) && normalizeInferenceEngineKey(ck) === normalizeInferenceEngineKey(engineName)) {
                  key = ck;
                  break;
                }
              }
            }
            var hasCmd = !!(key && commands && commands[key] && String(commands[key]).trim());
            btn.disabled = dis || !hasCmd;
            btn.setAttribute('aria-disabled', btn.disabled ? 'true' : 'false');
          });
          var ae = modal.getAttribute('data-active-engine');
          var activeEngineBtn = ae ? findRunModalEngineButton(modal, ae) : null;
          if (!activeEngineBtn || activeEngineBtn.disabled) {
            var firstOkEngine = modal.querySelector('[data-run-engine-btn]:not(:disabled)');
            if (firstOkEngine) {
              modal.setAttribute('data-active-engine', firstOkEngine.getAttribute('data-run-engine-btn') || '');
            }
          }
          syncRunModalMatrixUi(modal, meta);
        }

        function syncRunModalMatrixUi(modal, meta) {
          syncRunModalMatrixEngineRail(modal, meta);
          var modList = [];
          if (meta.useMatrix && meta.modalVisibleModules && meta.modalVisibleModules.length) {
            modList = meta.modalVisibleModules;
          } else if (meta.useEvalMatrix && meta.evalModalVisibleModules && meta.evalModalVisibleModules.length) {
            modList = meta.evalModalVisibleModules;
          }
          if (!modList.length) return;
          var am = modal.getAttribute('data-active-module');
          syncMatrixModuleTabSelection(modal.querySelectorAll('[data-run-module-tab]'), function (b) {
            return b.getAttribute('data-run-module-tab') === am;
          });
        }

        function findRunModalEngineButton(modal, engineId) {
          var want = normalizeInferenceEngineKey(engineId || '');
          var btns = modal.querySelectorAll('[data-run-engine-btn]');
          for (var i = 0; i < btns.length; i++) {
            var bid = btns[i].getAttribute('data-run-engine-btn') || '';
            if (normalizeInferenceEngineKey(bid) === want) return btns[i];
          }
          return null;
        }

        function applyVllmInputsFromPrefs(modal) {
          var p = readInferenceBrowserPrefs();
          var vp = qs(modal, '[data-vllm-port]');
          var vm = qs(modal, '[data-vllm-max-model-len]');
          var vg = qs(modal, '[data-vllm-gpu-mem]');
          if (vp && p.vllmPort) vp.value = p.vllmPort;
          if (vm && p.vllmMaxModelLen) vm.value = p.vllmMaxModelLen;
          if (vg && p.vllmGpuMem) vg.value = p.vllmGpuMem;
        }

        function render(modal) {
          try {
            var metaStr = modal.getAttribute('data-meta') || '{}';
            var meta = JSON.parse(metaStr);
            var st = getState(modal, meta);
            var pre = qs(modal, '[data-snippet]');

            if (!pre) {
              console.warn('RunCommand: Could not find [data-snippet] element');
              return;
            }
            var txt = '';
            var lang = 'shell';
            if (st.tab === 'shell') {
              txt = buildShell(meta, st);
              lang = 'shell';
            } else if (st.tab === 'compose') {
              txt = buildCompose(meta, st);
              lang = 'yaml';
            } else {
              txt = buildPython(meta, st);
              lang = 'python';
            }

            // Ensure we always have some output
            if (!txt) {
              txt = '# Unable to generate command. Please check your configuration.';
            }

            // Store raw command for copy: strip the two leading spaces on continuation lines so paste works
            var copyTxt = (lang === 'shell') ? txt.replace(/(\\)\n\s+/g, '$1\n') : txt;
            pre.dataset.copyText = copyTxt;
            // For shell: show continuation lines with two spaces (use content as-is if it already has \n  , else add)
            var displayTxt = (lang === 'shell' && txt.indexOf('\\\n') !== -1)
              ? (txt.indexOf('\\\n  ') !== -1 ? txt : txt.replace(/(\\)\n/g, '$1\n  ')) : txt;
            // Apply syntax highlighting
            pre.innerHTML = highlightSyntax(displayTxt, lang);
          } catch (err) {
            console.error('RunCommand render error:', err);
            var pre = qs(modal, '[data-snippet]');
            if (pre) {
              pre.innerHTML = '<span class="text-slate-500"># Error generating command. Please refresh and try again.</span>';
            }
          }
        }

        function openModal(modal) {
          modal.classList.remove('hidden');
          var metaStr = modal.getAttribute('data-meta') || '{}';
          var metaOpen = JSON.parse(metaStr);
          var prefs = readInferenceBrowserPrefs();
          if (metaOpen.useMatrix && metaOpen.defaultModuleId) {
            var defEng = metaOpen.defaultEngineId || 'vllm';
            var engBtn = prefs.matrixEngineId ? findRunModalEngineButton(modal, prefs.matrixEngineId) : null;
            var engToSet =
              engBtn && !engBtn.disabled
                ? engBtn.getAttribute('data-run-engine-btn') || defEng
                : defEng;
            modal.setAttribute('data-active-engine', engToSet);
            updateRunModalModuleTabAvailability(modal, metaOpen);
            var modToSet = metaOpen.defaultModuleId;
            if (prefs.matrixModuleId) {
              var modEl = modal.querySelector('[data-run-module-tab="' + prefs.matrixModuleId + '"]');
              if (modEl && !modEl.disabled) modToSet = prefs.matrixModuleId;
            }
            modal.setAttribute('data-active-module', modToSet);
            updateRunModalModuleTabAvailability(modal, metaOpen);
            syncRunModalMatrixUi(modal, metaOpen);
          } else if (metaOpen.useEvalMatrix && metaOpen.defaultEvalModuleId) {
            var modEval = metaOpen.defaultEvalModuleId;
            if (prefs.matrixModuleId) {
              var evEl = modal.querySelector('[data-run-module-tab="' + prefs.matrixModuleId + '"]');
              if (evEl && !evEl.disabled) modEval = prefs.matrixModuleId;
            }
            modal.setAttribute('data-active-module', modEval);
            syncRunModalMatrixUi(modal, metaOpen);
          }
          // Force active tab to shell if not set
          if (!modal.getAttribute('data-tab')) {
             var initTab = 'shell';
             if (metaOpen.useEvalMatrix && !metaOpen.evalShowShell && metaOpen.evalShowPython) {
               initTab = 'python';
             }
             modal.setAttribute('data-tab', initTab);
             // Update button visual state - only target actual buttons, not the modal itself
             var pickBtn = modal.querySelector('button[data-tab="' + initTab + '"]');
             if (pickBtn) {
                 var all = qsa(modal, 'button[data-tab]');
                 all.forEach(function (b) {
                    b.classList.remove('bg-nvidia-black','text-nvidia-white','border-nvidia-black','shadow-sm');
                    b.classList.add('bg-nvidia-gray-100','text-nvidia-gray-800','border-nvidia-gray-200');
                 });
                 pickBtn.classList.add('bg-nvidia-black','text-nvidia-white','border-nvidia-black','shadow-sm');
                 pickBtn.classList.remove('bg-nvidia-gray-100','text-nvidia-gray-800','border-nvidia-gray-200');
             }
          }
          // Show/hide vLLM config based on current engine
          updateVllmConfigVisibility(modal);
          applyVllmInputsFromPrefs(modal);
          render(modal);
        }

        function closeModal(modal) {
          modal.classList.add('hidden');
        }

        function setActiveTab(modal, btn) {
          // Only style actual tab buttons, not the modal container
          var all = qsa(modal, 'button[data-tab]');
          all.forEach(function (b) {
            b.classList.remove('bg-nvidia-black','text-nvidia-white','shadow-sm');
            b.classList.add('text-nvidia-gray-600','hover:text-nvidia-black','hover:bg-nvidia-gray-50');
          });
          btn.classList.add('bg-nvidia-black','text-nvidia-white','shadow-sm');
          btn.classList.remove('text-nvidia-gray-600','hover:text-nvidia-black','hover:bg-nvidia-gray-50');
          modal.setAttribute('data-tab', btn.getAttribute('data-tab') || 'shell');
          render(modal);
        }

        document.addEventListener('click', function (e) {
          var openBtn = e.target.closest('[data-run-open]');
          if (openBtn) {
            var modelId = openBtn.getAttribute('data-run-open');
            /** Prefer the modal immediately after this button (same RunCommand island). Catalog lists the same model in cards + table, so querySelector would always hit the hidden cards instance first. */
            var modal = openBtn.nextElementSibling;
            if (!modal || modal.getAttribute('data-run-modal') !== modelId) {
              modal = document.querySelector('[data-run-modal="' + modelId + '"]');
            }
            if (modal) openModal(modal);
            return;
          }
          var closeEl = e.target.closest('[data-run-close],[data-run-overlay]');
          if (closeEl) {
            var modal = closeEl.closest('[data-run-modal]');
            if (modal) closeModal(modal);
            return;
          }
          var tabBtn = e.target.closest('button[data-tab]');
          if (tabBtn) {
            var modal = tabBtn.closest('[data-run-modal]');
            // Make sure we're not treating the modal container as a tab button
            if (modal && tabBtn !== modal) setActiveTab(modal, tabBtn);
            return;
          }
          var copyBtn = e.target.closest('[data-run-copy]');
          if (copyBtn) {
            var modal = copyBtn.closest('[data-run-modal]');
            var pre = modal && qs(modal, '[data-snippet]');
            if (pre) {
              var toCopy = (pre.dataset && pre.dataset.copyText !== undefined) ? pre.dataset.copyText : (pre.textContent || '');
              navigator.clipboard.writeText(toCopy).then(function () {
                try {
                  var meta = JSON.parse(modal.getAttribute('data-meta') || '{}');
                  var useMatrix = !!(meta.useMatrix && meta.modalVisibleModules && meta.modalVisibleModules.length);
                  var useEvalMatrix = !!(meta.useEvalMatrix && meta.evalModalVisibleModules && meta.evalModalVisibleModules.length);
                  var moduleId = '';
                  var moduleLabel = '';
                  var engineId = '';
                  var jetsonDevice = '';
                  if (useMatrix) {
                    moduleId = modal.getAttribute('data-active-module') || '';
                    engineId = (modal.getAttribute('data-active-engine') || '').toLowerCase();
                    var mods = meta.modalVisibleModules || [];
                    var mi;
                    for (var i = 0; i < mods.length; i++) {
                      if (mods[i].id === moduleId) { mi = mods[i]; break; }
                    }
                    moduleLabel = mi ? (mi.label || mi.shortLabel || moduleId) : moduleId;
                  } else if (useEvalMatrix) {
                    moduleId = modal.getAttribute('data-active-module') || '';
                    engineId = 'one_shot';
                    var emods = meta.evalModalVisibleModules || [];
                    var ej;
                    for (var j = 0; j < emods.length; j++) {
                      if (emods[j].id === moduleId) { ej = emods[j]; break; }
                    }
                    moduleLabel = ej ? (ej.label || ej.shortLabel || moduleId) : moduleId;
                  } else {
                    var devEl = qs(modal, '[data-device]');
                    var engEl = qs(modal, '[data-engine]');
                    jetsonDevice = devEl ? devEl.value : '';
                    engineId = engEl ? engEl.value : '';
                    moduleLabel = jetsonDevice;
                    moduleId = jetsonDevice ? jetsonDevice.replace(/\s+/g, '_').toLowerCase() : '';
                  }
                  trackCopyInferenceCommand({
                    source: 'run_modal',
                    model_id: meta.modelId || '',
                    module_id: moduleId,
                    module_label: moduleLabel,
                    inference_engine: engineId,
                    jetson_device: useMatrix || useEvalMatrix ? undefined : jetsonDevice
                  });
                } catch (err) { /* ignore analytics */ }
              });
              var label = copyBtn.querySelector('[data-run-copy-label]');
              var original = label ? (label.textContent || '') : (copyBtn.textContent || '');
              var resetLabel = copyBtn.getAttribute('data-run-copy-reset-label') || 'Copy serve command';
              if (label) label.textContent = 'Copied';
              else copyBtn.textContent = 'Copied';
              setTimeout(function () {
                if (label) label.textContent = original || resetLabel;
                else copyBtn.textContent = original || resetLabel;
              }, 1200);
            }
            return;
          }

          var modTab = e.target.closest('[data-run-module-tab]');
          if (modTab) {
            if (modTab.disabled) return;
            var modalM = modTab.closest('[data-run-modal]');
            if (modalM) {
              var mid = modTab.getAttribute('data-run-module-tab');
              if (mid) {
                modalM.setAttribute('data-active-module', mid);
                writeInferenceBrowserPrefsPatch({ matrixModuleId: mid });
              }
              var metaM = JSON.parse(modalM.getAttribute('data-meta') || '{}');
              updateRunModalModuleTabAvailability(modalM, metaM);
              updateVllmConfigVisibility(modalM);
              render(modalM);
            }
            return;
          }

          var engMatrixBtn = e.target.closest('[data-run-engine-btn]');
          if (engMatrixBtn && engMatrixBtn.closest('[data-run-modal]')) {
            if (engMatrixBtn.disabled) return;
            var modalE = engMatrixBtn.closest('[data-run-modal]');
            var eid = engMatrixBtn.getAttribute('data-run-engine-btn');
            if (eid) {
              modalE.setAttribute('data-active-engine', eid);
              writeInferenceBrowserPrefsPatch({ matrixEngineId: eid });
            }
            var metaE = JSON.parse(modalE.getAttribute('data-meta') || '{}');
            updateRunModalModuleTabAvailability(modalE, metaE);
            updateVllmConfigVisibility(modalE);
            render(modalE);
            return;
          }

          var advToggle = e.target.closest('[data-run-advanced-toggle]');
          if (advToggle) {
            var modal = advToggle.closest('[data-run-modal]');
            var scope = advToggle.closest('[data-run-advanced-scope]');
            var panel = scope ? scope.querySelector('[data-advanced]') : (modal && qs(modal, '[data-advanced]'));
            var toggleText = advToggle.querySelector('[data-toggle-text]');
            var toggleIcon = advToggle.querySelector('[data-toggle-icon]');
            if (panel) {
              panel.classList.toggle('hidden');
              // Update toggle text and icon
              if (toggleText) {
                toggleText.textContent = panel.classList.contains('hidden') ? 'Show Advanced' : 'Hide Advanced';
              }
              if (toggleIcon) {
                toggleIcon.style.transform = panel.classList.contains('hidden') ? '' : 'rotate(180deg)';
              }
            }
            return;
          }

          // vLLM reset button
          var vllmReset = e.target.closest('[data-vllm-reset]');
          if (vllmReset) {
            var modal = vllmReset.closest('[data-run-modal]');
            if (modal) {
              clearVllmFieldsInInferenceBrowserPrefs();
              var vllmPort = qs(modal, '[data-vllm-port]');
              var vllmMaxLen = qs(modal, '[data-vllm-max-model-len]');
              var vllmGpuMem = qs(modal, '[data-vllm-gpu-mem]');
              if (vllmPort) vllmPort.value = '';
              if (vllmMaxLen) vllmMaxLen.value = '';
              if (vllmGpuMem) vllmGpuMem.value = '';
              render(modal);
            }
            return;
          }
        });

        document.addEventListener('change', function (e) {
          var modal = e.target.closest('[data-run-modal]');
          if (modal) {
            if (e.target.matches('[data-engine]') || e.target.matches('[data-device]')) {
              updateVllmConfigVisibility(modal);
            }
            render(modal);
          }
        });
        document.addEventListener('input', function (e) {
          var modal = e.target.closest('[data-run-modal]');
          if (modal) {
            var t = e.target;
            if (t && t.matches && t.matches('[data-vllm-port]')) {
              writeInferenceBrowserPrefsPatch({ vllmPort: t.value || undefined });
            } else if (t && t.matches && t.matches('[data-vllm-max-model-len]')) {
              writeInferenceBrowserPrefsPatch({ vllmMaxModelLen: t.value || undefined });
            } else if (t && t.matches && t.matches('[data-vllm-gpu-mem]')) {
              writeInferenceBrowserPrefsPatch({ vllmGpuMem: t.value || undefined });
            }
            render(modal);
          }
        });
      })();
    </script>

