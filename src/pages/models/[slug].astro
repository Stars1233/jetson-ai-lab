---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ModelServeSection from '../../components/ModelServeSection.astro';
import ModelCallSection from '../../components/ModelCallSection.astro';
import ModelBenchmarkSection from '../../components/ModelBenchmarkSection.astro';
import ModelOneShotSection from '../../components/ModelOneShotSection.astro';
import { getSupportedInferenceEngines, sortEnginesForUi } from '../../lib/modelFrontmatterAdapter';
import benchmarksData from '../../data/benchmarks.json';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

// Generate HuggingFace URL from hf_checkpoint if huggingface_url not provided
const huggingfaceUrl = data.huggingface_url || (data.hf_checkpoint ? `https://huggingface.co/${data.hf_checkpoint}` : null);
const isGemma4Family = data.family === 'Google Gemma4';

const sortedEngines = sortEnginesForUi(getSupportedInferenceEngines(data));

const benchmarkEntry = data.benchmark_key
  ? ((benchmarksData.models as any[]).find((m) => m.name === data.benchmark_key) ?? null)
  : null;

const benchmarkSeries = (data.benchmark_series ?? [])
  .map((k) => (benchmarksData.models as any[]).find((m) => m.name === k) ?? null)
  .filter((m): m is NonNullable<typeof m> => m !== null);

const inferenceNeedsHfToken = sortedEngines.some((e) => {
  const cmds = [
    e.serve_command_orin,
    e.serve_command_thor,
    e.run_command_orin,
    e.run_command_thor,
    e.run_command,
  ];
  return cmds.some((c) => c && c.includes('HF_TOKEN'));
});
---

<Layout title={data.title} description={data.short_description}>
  {/* Hero Section */}
  <section class="bg-nvidia-black text-nvidia-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center space-x-3 mb-6">
            {data.is_new && (
              <span class="bg-nvidia-green text-nvidia-black px-4 py-2 rounded-full text-sm font-semibold">New</span>
            )}
            {data.type && (
              <span class="text-nvidia-gray-300 font-semibold text-lg">{data.type}</span>
            )}
          </div>
          <h1 class="text-5xl font-bold mb-6">{data.title}</h1>
          <p class="text-xl text-nvidia-gray-300 mb-8 leading-relaxed">
            {data.short_description}
          </p>
          
          {/* Action Button - Primary CTA only */}
          <div class="flex flex-wrap gap-3">
            {/* Run on Jetson - scrolls to inference section */}
            <a
              href="#run-on-jetson"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-nvidia-green hover:bg-[#9aeb00] text-black font-semibold rounded-lg transition-colors"
            >
              Run on Jetson
            </a>
          </div>
        </div>
        <div class="bg-nvidia-gray-800 rounded-xl p-8 border border-nvidia-gray-700">
          <div class="space-y-6">
            <div class="flex justify-between items-center py-3 border-b border-nvidia-gray-700">
              <span class="text-nvidia-gray-300 font-medium">Memory Requirement</span>
              <span class="font-bold text-nvidia-white">{data.memory_requirements}</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-nvidia-gray-700">
              <span class="text-nvidia-gray-300 font-medium">Precision</span>
              <span class="font-bold text-nvidia-white">{data.precision}</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-nvidia-gray-700">
              <span class="text-nvidia-gray-300 font-medium">Vision (VLM)</span>
              <span class="font-bold text-nvidia-white">{data.vision_capable ? 'Yes' : 'No'}</span>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-nvidia-gray-300 font-medium">Size</span>
              <span class="font-bold text-nvidia-white">{data.model_size}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {!data.hide_run_button && sortedEngines.length > 0 && (
    <div id="run-on-jetson" class="scroll-mt-20">
      <section
        id="serve-model-and-call"
        class="bg-nvidia-gray-50 border-b border-nvidia-gray-200 relative overflow-hidden scroll-mt-20"
        aria-labelledby="serve-the-model-heading"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-cover bg-center bg-no-repeat opacity-[0.12]"
          style="background-image: url('/images/inference-call-band.png');"
          aria-hidden="true"
        />
        <div class="relative z-[1]">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16">
            <h2 id="serve-the-model-heading" class="text-3xl font-bold text-nvidia-black mb-0">
              Serve the model
            </h2>
          </div>
          <ModelServeSection
            modelSlug={entry.slug}
            engines={sortedEngines}
            needsHfToken={inferenceNeedsHfToken}
            matrixModulesDisabled={data.matrix_modules_disabled}
            sectionClass="!bg-transparent !border-b-0 !scroll-mt-0 pt-8 pb-8"
          />
          <ModelCallSection
            modelSlug={entry.slug}
            engines={sortedEngines}
            hfCheckpoint={data.hf_checkpoint}
            clientCall={data.client_call}
            sectionClass="!bg-transparent !border-b-0 !border-t-0 !scroll-mt-0 pt-10 pb-16"
          />
        </div>
      </section>
      <ModelOneShotSection oneShot={data.one_shot_inference} modelSlug={entry.slug} />
    </div>
  )}

  {benchmarkEntry && (
    <ModelBenchmarkSection entry={benchmarkEntry} seriesEntries={benchmarkSeries} />
  )}

  {/* Model Details / Description Section */}
  <section class="py-16 bg-nvidia-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <h2 class="text-3xl font-bold text-nvidia-black">Model Details</h2>
        
        {/* External Resources - next to Model Details heading */}
        {(data.build_nvidia_url || huggingfaceUrl) && (
          <div class="flex flex-wrap gap-3">
            {data.build_nvidia_url && (
              <a 
                href={data.build_nvidia_url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="relative inline-flex items-center gap-2 rounded-lg border border-gray-700 bg-black px-4 pt-2.5 pb-4 font-semibold text-white transition-colors hover:bg-gray-800 after:absolute after:right-4 after:bottom-2 after:left-4 after:h-[3px] after:rounded-full after:bg-[#76b900] after:content-['']"
              >
                <img src="https://www.nvidia.com/favicon.ico" alt="NVIDIA" class="h-5 w-5 brightness-0 invert" />
                Try on build.nvidia.com
              </a>
            )}
            {huggingfaceUrl && (
              <a 
                href={huggingfaceUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="relative inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-gray-100 px-4 pt-2.5 pb-4 font-semibold text-black transition-colors hover:bg-gray-200 after:absolute after:right-4 after:bottom-2 after:left-4 after:h-[3px] after:rounded-full after:bg-[#FFD21E] after:content-['']"
              >
                <img src="/images/icons/hf-logo.png" alt="HuggingFace" class="w-5 h-5" />
                View on HuggingFace
              </a>
            )}
          </div>
        )}
      </div>
      {isGemma4Family && (
        <p class="mb-6 rounded-lg border border-nvidia-gray-200 bg-nvidia-gray-50 px-4 py-3 text-sm text-nvidia-gray-700">
          If you want to learn more about the Gemma 4 family and the different ways to run it on Jetson, check out the{' '}
          <a href="/tutorials/gemma4-on-jetson" class="font-semibold text-nvidia-green hover:underline">
            Gemma 4 on Jetson tutorial
          </a>
          .
        </p>
      )}
      <div class="prose prose-lg text-nvidia-gray-600 max-w-none">
        <Content />
      </div>
    </div>
  </section>
</Layout>

<script>
  // Body content device tabs (inside markdown-rendered sections)
  document.querySelectorAll('.device-tabs').forEach(group => {
    const buttons = group.querySelectorAll('.device-tab');
    const panels = group.querySelectorAll('.device-panel');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        buttons.forEach(b => b.classList.toggle('active', b.getAttribute('data-target') === target));
        panels.forEach(p => {
          if (p.getAttribute('data-panel') === target) {
            p.style.display = '';
          } else {
            p.style.display = 'none';
          }
        });
      });
    });
  });
</script>

<style is:global>
  .device-tabs {
    margin: 1.5rem 0;
  }
  .device-tab-bar {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 1.5rem;
  }
  .device-tab {
    padding-bottom: 1rem;
    font-size: 1.125rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: #6b7280;
    transition: all 0.2s;
  }
  .device-tab.active {
    color: #76b900;
    border-bottom-color: #76b900;
  }
  .device-tab:not(.active):hover {
    color: #1a1a1a;
    border-bottom-color: #d1d5db;
  }
</style>
