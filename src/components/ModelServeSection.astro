---
import {
	applyMatrixModuleDisabledFlags,
	engineSupportsModule,
	serveCommandForMatrixCell,
	visibleModulesForEngines,
	type SupportedEngineEntry,
} from '../lib/inferenceCommands';
import JetsonEngineRail from './matrix/JetsonEngineRail.astro';
import JetsonModuleTabBar from './matrix/JetsonModuleTabBar.astro';
import type { MatrixModuleTabItem } from './matrix/panelTypes';

interface Props {
	engines: SupportedEngineEntry[];
	sectionClass?: string;
	needsHfToken?: boolean;
	/** Model collection slug — used for GA4 copy events */
	modelSlug?: string;
	/** From model front matter `matrix_modules_disabled` */
	matrixModulesDisabled?: string[];
}

const {
	engines: sortedEngines,
	sectionClass = '',
	needsHfToken = false,
	modelSlug = '',
	matrixModulesDisabled,
} = Astro.props as Props;

const visibleModules = applyMatrixModuleDisabledFlags(
	visibleModulesForEngines(sortedEngines),
	matrixModulesDisabled
);
const defaultEngineEntry = sortedEngines[0];
const defaultEngineName = defaultEngineEntry?.engine ?? '';

function moduleTabDisabledForEngine(
	mod: (typeof visibleModules)[0],
	eng: SupportedEngineEntry | undefined
): boolean {
	if (mod.disabled === true) return true;
	if (!eng) return false;
	return !engineSupportsModule(eng, mod.id);
}

const defaultModuleId =
	visibleModules.find((m) => !moduleTabDisabledForEngine(m, defaultEngineEntry))?.id ??
	visibleModules[0]?.id ??
	'';
const _firstEnabledModIdx = visibleModules.findIndex((m) => !moduleTabDisabledForEngine(m, defaultEngineEntry));
const firstEnabledModuleIndex = _firstEnabledModIdx >= 0 ? _firstEnabledModIdx : 0;

function engineIsVllm(name: string): boolean {
	return name.toLowerCase().replace(/[.\-_]/g, '') === 'vllm';
}

const hasVllmEngine = sortedEngines.some((e) => engineIsVllm(e.engine));
const showAdvancedConfiguration = needsHfToken || hasVllmEngine;

const commandsRecord: Record<string, string> = {};
for (const mod of visibleModules) {
	for (const eng of sortedEngines) {
		commandsRecord[`${mod.id}::${eng.engine}`] = serveCommandForMatrixCell(eng, mod);
	}
}

const modulesSupportedByEngine: Record<string, string[] | null> = {};
for (const eng of sortedEngines) {
	const ms = eng.modules_supported;
	if (ms === undefined) modulesSupportedByEngine[eng.engine] = null;
	else if (ms.length === 0) modulesSupportedByEngine[eng.engine] = [];
	else modulesSupportedByEngine[eng.engine] = [...ms];
}

const panelConfigJson = JSON.stringify({
	commands: commandsRecord,
	modules: visibleModules.map((m) => ({
		id: m.id,
		label: m.label,
		platformKey: m.platformKey,
		globalDisabled: m.disabled === true,
	})),
	modulesSupportedByEngine,
	needsHfToken,
	defaultModule: defaultModuleId,
	defaultEngine: defaultEngineName,
	modelSlug,
});

const servePanelModuleItems: MatrixModuleTabItem[] = visibleModules.map((m) => ({
	id: m.id,
	label: m.label,
	tabKicker: m.tabKicker,
	tabTitleBold: m.tabTitleBold,
	tabSubtitleGray: m.tabSubtitleGray,
	iconSrc: m.iconSrc,
	iconBadgeFamily: m.iconBadgeFamily,
	iconBadgeMemory: m.iconBadgeMemory,
	globalDisabled: m.disabled === true,
}));
const servePanelTabDisabled = visibleModules.map((m) => {
	if (m.disabled === true) return true;
	return !sortedEngines.some((e) => engineSupportsModule(e, m.id));
});
const servePanelEngineRows = sortedEngines.map((e) => ({
	key: e.engine,
	title: e.engine,
	subtitle: e.type?.trim() ? e.type : undefined,
}));
---

{
		sortedEngines.length > 0 && visibleModules.length > 0 && (
		<div
			data-inference-matrix-root
			role="region"
			aria-labelledby="serve-start-server-heading"
			class:list={['py-16 bg-nvidia-gray-50 border-b border-nvidia-gray-200 scroll-mt-20', sectionClass]}
		>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="mb-8">
					<h3 id="serve-start-server-heading" class="text-2xl font-bold text-nvidia-black mb-2">
						Start server
					</h3>
					<p class="text-sm text-nvidia-gray-600">
						Choose module, then engine and optional parameters on the left, then copy the serve command by clicking the
						button on the right.
					</p>
				</div>

				<script
					type="application/json"
					id="inference-panel-config"
					set:html={panelConfigJson}
				/>

				<div
					class="bg-white rounded-xl border border-nvidia-gray-200 shadow-sm overflow-hidden"
					id="inference-matrix-panel"
					role="tabpanel"
					aria-label="Commands for selected module and engine"
				>
					<JetsonModuleTabBar
						variant="serve-panel"
						modules={servePanelModuleItems}
						tabDisabled={servePanelTabDisabled}
						firstEnabledIndex={firstEnabledModuleIndex >= 0 ? firstEnabledModuleIndex : 0}
						tabIdPrefix="inference-tab-"
					/>

					<div class="flex flex-col lg:flex-row min-h-0 min-w-0 items-stretch">
						<aside class="w-full lg:w-[min(100%,18rem)] xl:w-80 shrink-0 border-b lg:border-b-0 lg:border-r border-nvidia-gray-100 bg-nvidia-gray-50/80 min-w-0 flex flex-col">
							<h3 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider px-4 pt-4 lg:pt-5 lg:px-4 mb-2 lg:mb-3">
								Inference Engine
							</h3>
							<JetsonEngineRail
								variant="serve-panel"
								engines={servePanelEngineRows}
								selectedKey={defaultEngineName}
							/>

							{showAdvancedConfiguration && (
								<div class="mt-auto border-t border-nvidia-gray-200 px-3 py-4 lg:px-4">
									<div class="flex flex-wrap items-center justify-between gap-2 mb-2">
										<h3 class="text-[10px] font-bold text-nvidia-gray-400 uppercase tracking-wider leading-tight">
											Advanced
										</h3>
										<button
											type="button"
											id="inference-advanced-toggle"
											class="text-[11px] font-medium text-nvidia-green hover:text-nvidia-green/80 flex items-center gap-0.5 shrink-0"
											aria-expanded="false"
											aria-controls="inference-advanced-body"
										>
											<span data-inference-adv-toggle-text>Show</span>
											<svg
												data-inference-adv-toggle-icon
												class="w-3 h-3 transition-transform duration-200 shrink-0"
												fill="none"
												stroke="currentColor"
												viewBox="0 0 24 24"
												aria-hidden="true"
											>
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													stroke-width="2"
													d="M19 9l-7 7-7-7"
												/>
											</svg>
										</button>
									</div>
									<div id="inference-advanced-body" class="hidden space-y-4 pt-1">
										<div class="grid grid-cols-1 gap-y-4">
											{needsHfToken && (
												<section id="inference-hf-section" class="hidden">
													<h4 class="text-[10px] font-bold text-nvidia-gray-400 uppercase tracking-wider mb-1.5">
														Authentication
													</h4>
													<label class="block text-xs font-medium text-nvidia-gray-700 mb-1">
														Hugging Face Token
														<span class="text-red-500 ml-0.5">*</span>
													</label>
													<input
														id="inference-hf-token"
														type="text"
														placeholder="hf_..."
														class="w-full bg-white border border-nvidia-gray-200 text-nvidia-black text-xs rounded-lg px-2.5 py-2 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none placeholder:text-nvidia-gray-300 font-mono"
													/>
													<p class="text-[9px] text-nvidia-gray-400 mt-1 leading-snug">
														Thor + HF_TOKEN models.{' '}
														<a
															href="https://huggingface.co/settings/tokens"
															target="_blank"
															rel="noopener noreferrer"
															class="text-nvidia-green hover:underline"
														>
															Token
														</a>
														. Not stored.
													</p>
												</section>
											)}

											{hasVllmEngine && (
												<section id="inference-vllm-section" class="hidden">
													<h4 class="text-[10px] font-bold text-nvidia-gray-400 uppercase tracking-wider mb-1.5">
														vLLM
													</h4>
													<p class="text-[10px] text-nvidia-gray-500 mb-2 leading-snug">
														When engine is vLLM. Empty = YAML defaults.
													</p>
													<div class="space-y-3">
														<div>
															<label class="block text-[10px] font-medium text-nvidia-gray-600 mb-0.5">
																Port
															</label>
															<input
																id="inference-vllm-port"
																type="number"
																min="1024"
																max="65535"
																placeholder="8000"
																class="w-full bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-xs focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300"
															/>
														</div>
														<div>
															<label class="block text-[10px] font-medium text-nvidia-gray-600 mb-0.5">
																Max length
															</label>
															<input
																id="inference-vllm-max-len"
																type="number"
																min="512"
																max="131072"
																step="512"
																placeholder="32000"
																class="w-full bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-xs focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300"
															/>
														</div>
														<div>
															<label class="block text-[10px] font-medium text-nvidia-gray-600 mb-0.5">
																GPU mem util
															</label>
															<input
																id="inference-vllm-gpu"
																type="number"
																min="0.1"
																max="1.0"
																step="0.05"
																placeholder="0.9"
																class="w-full bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-xs focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300"
															/>
														</div>
														<button
															type="button"
															id="inference-vllm-reset"
															class="text-[10px] text-nvidia-gray-500 hover:text-nvidia-black underline decoration-dotted"
														>
															Reset vLLM fields
														</button>
													</div>
												</section>
											)}
										</div>
									</div>
								</div>
							)}
						</aside>

						<div class="flex-1 min-w-0 w-full p-4 sm:p-6 bg-nvidia-gray-50/50 flex flex-col">
							<div class="min-w-0 flex-1 flex flex-col w-full max-w-full">
								<div class="min-w-0 shrink-0 mb-3">
									<p class="text-xs font-semibold text-nvidia-gray-400 uppercase tracking-wide m-0">
										Command
									</p>
									<p id="inference-command-subtitle" class="text-sm text-nvidia-gray-700 mt-1 break-words m-0">
										<span class="font-medium text-nvidia-black" id="inference-command-mod-label" />
										<span class="text-nvidia-gray-400 mx-1">·</span>
										<span id="inference-command-eng-label" />
									</p>
								</div>

								<p id="inference-command-empty" class="hidden text-nvidia-gray-500 italic text-center py-8">
									No command for this module and engine in model data.
								</p>

								<div id="inference-command-block" class="relative min-w-0 w-full max-w-full flex-1 flex flex-col">
									<div
										class="inference-matrix-code-wrap relative rounded-xl border border-gray-800 shadow-lg bg-[#0f172a] flex-1 min-h-[8rem] w-full max-w-full"
									>
										<button
											type="button"
											id="inference-matrix-copy-btn"
											class="absolute top-2 right-2 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/80 backdrop-blur-sm border-2 border-nvidia-green text-nvidia-gray-800 shadow-md hover:bg-white hover:text-nvidia-green transition-all text-xs font-bold disabled:opacity-40 disabled:pointer-events-none disabled:border-nvidia-gray-300 disabled:text-nvidia-gray-600 disabled:shadow-sm disabled:hover:border-nvidia-gray-300 disabled:hover:text-nvidia-gray-600"
											disabled
										>
											<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
											</svg>
											<span data-inference-copy-label>Copy serve command</span>
										</button>
										<pre
											class="text-sm font-mono text-slate-200 whitespace-pre-wrap break-words [overflow-wrap:anywhere] p-4 m-0 min-h-[8rem]"
										><code id="inference-command-display" class="block w-full max-w-full whitespace-pre-wrap break-words [overflow-wrap:anywhere]" /></pre>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

<style is:global>
	.inference-matrix-code-wrap {
		width: 100%;
		max-width: 100%;
		min-width: 0;
		overflow-x: hidden;
	}

	/* Horizontal scrollers: avoid an unwanted vertical scrollbar in some browsers. */
	.inference-matrix-module-bar,
	.inference-matrix-engine-bar {
		overflow-y: hidden;
	}
</style>

<script>
	import {
		applyHfTokenToCommand,
		applyVllmOverridesToCommand,
	} from '../lib/inferenceCommandOverrides';
	import { highlightSyntax, shellDisplayAndCopy } from '../lib/commandSyntaxHighlight';
	import { trackCopyInferenceCommand } from '../lib/analyticsInference';
	import {
		readInferenceBrowserPrefs,
		writeInferenceBrowserPrefsPatch,
		clearVllmFieldsInInferenceBrowserPrefs,
		normalizeInferenceEngineKey,
	} from '../lib/inferenceBrowserPrefs';
	import {
		applyMatrixModuleTabDisabledVisual,
		clearMatrixModuleTabDisabledVisual,
		syncMatrixEngineRailSelection,
		syncMatrixModuleTabSelection,
	} from '../lib/matrixUiSync';

	type PanelCfg = {
		commands: Record<string, string>;
		modules: { id: string; label: string; platformKey: string; globalDisabled?: boolean }[];
		modulesSupportedByEngine: Record<string, string[] | null>;
		needsHfToken: boolean;
		defaultModule: string;
		defaultEngine: string;
		modelSlug: string;
	};

	function normVllm(engine: string): boolean {
		return engine.toLowerCase().replace(/[.\-_]/g, '') === 'vllm';
	}

	/** Match panel `data-engine` to `activeEngine` (YAML may use "Ollama" vs internal "ollama"). */
	function normEngineKey(name: string): string {
		return name.trim().toLowerCase().replace(/[.\-_]/g, '');
	}

	function initJetsonInferenceMatrix() {
		const section = document.querySelector('[data-inference-matrix-root]');
		const jsonEl = document.getElementById('inference-panel-config');
		if (!section || !jsonEl || (section as HTMLElement).dataset.inferenceInit === '1') return;
		let cfg: PanelCfg;
		try {
			cfg = JSON.parse(jsonEl.textContent || '{}') as PanelCfg;
		} catch {
			return;
		}
		(section as HTMLElement).dataset.inferenceInit = '1';

		const advToggle = document.getElementById('inference-advanced-toggle');
		const advBody = document.getElementById('inference-advanced-body');
		const advToggleText = advToggle?.querySelector('[data-inference-adv-toggle-text]');
		const advToggleIcon = advToggle?.querySelector('[data-inference-adv-toggle-icon]');
		advToggle?.addEventListener('click', () => {
			if (!advBody || !advToggle) return;
			advBody.classList.toggle('hidden');
			const open = !advBody.classList.contains('hidden');
			advToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
			if (advToggleText) advToggleText.textContent = open ? 'Hide' : 'Show';
			if (advToggleIcon) (advToggleIcon as HTMLElement).style.transform = open ? 'rotate(180deg)' : '';
		});

		const moduleTabs = section.querySelectorAll<HTMLButtonElement>('.module-tab-btn');
		const engineBtns = section.querySelectorAll<HTMLButtonElement>('.engine-rail-btn');
		const display = document.getElementById('inference-command-display');
		const copyBtn = document.getElementById('inference-matrix-copy-btn');
		const modLabelEl = document.getElementById('inference-command-mod-label');
		const engLabelEl = document.getElementById('inference-command-eng-label');
		const emptyEl = document.getElementById('inference-command-empty');
		const blockEl = document.getElementById('inference-command-block');
		const hfSection = document.getElementById('inference-hf-section');
		const vllmSection = document.getElementById('inference-vllm-section');
		const hfInput = document.getElementById('inference-hf-token') as HTMLInputElement | null;
		const vllmPort = document.getElementById('inference-vllm-port') as HTMLInputElement | null;
		const vllmMax = document.getElementById('inference-vllm-max-len') as HTMLInputElement | null;
		const vllmGpu = document.getElementById('inference-vllm-gpu') as HTMLInputElement | null;

		const prefs = readInferenceBrowserPrefs();
		let activeModule = cfg.defaultModule;
		if (prefs.matrixModuleId) {
			const pm = cfg.modules.find((m) => m.id === prefs.matrixModuleId && !m.globalDisabled);
			if (pm) activeModule = prefs.matrixModuleId;
		}
		let activeEngine = cfg.defaultEngine;
		if (prefs.matrixEngineId) {
			const want = normalizeInferenceEngineKey(prefs.matrixEngineId);
			const matchBtn = Array.from(engineBtns).find(
				(b) => normalizeInferenceEngineKey(b.getAttribute('data-engine') || '') === want,
			);
			if (matchBtn) {
				activeEngine = matchBtn.getAttribute('data-engine')?.trim() || activeEngine;
			}
		}
		if (prefs.vllmPort && vllmPort) vllmPort.value = prefs.vllmPort;
		if (prefs.vllmMaxModelLen && vllmMax) vllmMax.value = prefs.vllmMaxModelLen;
		if (prefs.vllmGpuMem && vllmGpu) vllmGpu.value = prefs.vllmGpuMem;

		let inferenceCopyLabelTimer: ReturnType<typeof setTimeout> | null = null;

		function resetInferenceCopyLabel() {
			if (inferenceCopyLabelTimer != null) {
				clearTimeout(inferenceCopyLabelTimer);
				inferenceCopyLabelTimer = null;
			}
			const label = copyBtn?.querySelector('[data-inference-copy-label]');
			if (label) label.textContent = 'Copy serve command';
		}

		function moduleMeta(id: string) {
			return cfg.modules.find((m) => m.id === id);
		}

		const modulesSupportedByEngine = cfg.modulesSupportedByEngine || {};

		function applyModuleTabsEnabledState() {
			moduleTabs.forEach((btn) => {
				const global = btn.dataset.moduleGlobalDisabled === '1';
				const dis = global;
				btn.disabled = dis;
				if (dis) {
					applyMatrixModuleTabDisabledVisual(btn);
				} else {
					clearMatrixModuleTabDisabledVisual(btn);
				}
			});
		}

		function refreshCommand() {
			resetInferenceCopyLabel();
			const resolvedKey =
				commandKeyForUiEngine(activeEngine) || `${activeModule}::${activeEngine}`;
			let base = cfg.commands[resolvedKey] || '';
			const meta = moduleMeta(activeModule);
			if (modLabelEl) modLabelEl.textContent = meta?.label || '';
			if (engLabelEl) engLabelEl.textContent = activeEngine;

			const isVllm = normVllm(activeEngine);
			if (vllmSection) {
				vllmSection.classList.toggle('hidden', !isVllm);
			}

			const isThor = meta?.platformKey === 'thor';
			if (hfSection && cfg.needsHfToken) {
				hfSection.classList.toggle('hidden', !isThor);
			}

			if (!base) {
				emptyEl?.classList.remove('hidden');
				blockEl?.classList.add('hidden');
				if (display) {
					display.textContent = '';
					display.innerHTML = '';
				}
				if (copyBtn) {
					copyBtn.setAttribute('data-code', '');
					copyBtn.disabled = true;
				}
			} else {
				emptyEl?.classList.add('hidden');
				blockEl?.classList.remove('hidden');
				let cmd = base;
				if (isVllm) {
					cmd = applyVllmOverridesToCommand(cmd, {
						vllmPort: vllmPort?.value?.trim(),
						vllmMaxModelLen: vllmMax?.value?.trim(),
						vllmGpuMem: vllmGpu?.value?.trim(),
					});
				}
				const tok = hfInput?.value?.trim() || '';
				cmd = applyHfTokenToCommand(cmd, tok);
				const { display: shellDisplay, copy: shellCopy } = shellDisplayAndCopy(cmd);
				if (display) {
					display.innerHTML = highlightSyntax(shellDisplay, 'shell');
				}
				if (copyBtn) {
					copyBtn.setAttribute('data-code', shellCopy);
					copyBtn.disabled = !shellCopy;
				}
			}
		}

		function commandKeyForUiEngine(uiEngine: string): string | null {
			const keys = Object.keys(cfg.commands).filter((k) => k.startsWith(`${activeModule}::`));
			const want = normEngineKey(uiEngine);
			for (const k of keys) {
				const part = k.slice(activeModule.length + 2);
				if (normEngineKey(part) === want) return k;
			}
			return null;
		}

		function syncEngineAvailability() {
			engineBtns.forEach((btn) => {
				const eng = btn.getAttribute('data-engine')?.trim() || '';
				const key = commandKeyForUiEngine(eng);
				const hasCmd = !!(key && cfg.commands[key]?.trim());
				btn.disabled = !hasCmd;
				btn.setAttribute('aria-disabled', hasCmd ? 'false' : 'true');
			});
		}

		function syncEngineRailSelection() {
			syncMatrixEngineRailSelection(
				engineBtns,
				(btn) => {
					const eng = btn.getAttribute('data-engine')?.trim() || '';
					return normEngineKey(eng) === normEngineKey(activeEngine);
				},
				'serve-panel',
			);
		}

		function setActiveModule(moduleId: string) {
			activeModule = moduleId;
			writeInferenceBrowserPrefsPatch({ matrixModuleId: moduleId });
			syncMatrixModuleTabSelection(moduleTabs, (btn) => (btn as HTMLButtonElement).dataset.module === moduleId);
			syncEngineAvailability();
			const activeKey = `${activeModule}::${activeEngine}`;
			const activeCmdKey = commandKeyForUiEngine(activeEngine);
			const activeRawKey = `${activeModule}::${activeEngine}`;
			const hasActiveCmd = !!(
				(activeCmdKey && cfg.commands[activeCmdKey]?.trim()) ||
				cfg.commands[activeRawKey]?.trim()
			);
			if (!hasActiveCmd) {
				const fallback = Array.from(engineBtns).find((b) => !b.disabled)?.getAttribute('data-engine')?.trim();
				if (fallback) {
					setActiveEngine(fallback);
					return;
				}
			}
			refreshCommand();
			syncEngineRailSelection();
		}

		function setActiveEngine(engineName: string) {
			activeEngine = engineName;
			writeInferenceBrowserPrefsPatch({ matrixEngineId: engineName });
			setActiveModule(activeModule);

			document.dispatchEvent(
				new CustomEvent('jetson-inference-engine-changed', {
					bubbles: true,
					detail: { engine: activeEngine },
				}),
			);
		}

		moduleTabs.forEach((btn) => {
			btn.addEventListener('click', () => {
				if (btn.disabled) return;
				const id = btn.dataset.module;
				if (id) setActiveModule(id);
			});
		});

		engineBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				if (btn.disabled) return;
				const eng = btn.getAttribute('data-engine')?.trim();
				if (eng) setActiveEngine(eng);
			});
		});

		hfInput?.addEventListener('input', () => refreshCommand());
		vllmPort?.addEventListener('input', () => {
			writeInferenceBrowserPrefsPatch({ vllmPort: vllmPort.value || undefined });
			refreshCommand();
		});
		vllmMax?.addEventListener('input', () => {
			writeInferenceBrowserPrefsPatch({ vllmMaxModelLen: vllmMax.value || undefined });
			refreshCommand();
		});
		vllmGpu?.addEventListener('input', () => {
			writeInferenceBrowserPrefsPatch({ vllmGpuMem: vllmGpu.value || undefined });
			refreshCommand();
		});

		document.getElementById('inference-vllm-reset')?.addEventListener('click', () => {
			clearVllmFieldsInInferenceBrowserPrefs();
			if (vllmPort) vllmPort.value = '';
			if (vllmMax) vllmMax.value = '';
			if (vllmGpu) vllmGpu.value = '';
			refreshCommand();
		});

		copyBtn?.addEventListener('click', () => {
			const raw = copyBtn.getAttribute('data-code') || '';
			if (!raw) return;
			const label = copyBtn.querySelector('[data-inference-copy-label]');
			const meta = moduleMeta(activeModule);
			void navigator.clipboard.writeText(raw).then(() => {
				trackCopyInferenceCommand({
					source: 'model_page',
					model_id: cfg.modelSlug || 'unknown',
					module_id: activeModule,
					module_label: meta?.label || activeModule,
					inference_engine: activeEngine,
				});
			});
			if (label) {
				if (inferenceCopyLabelTimer != null) {
					clearTimeout(inferenceCopyLabelTimer);
					inferenceCopyLabelTimer = null;
				}
				label.textContent = 'Copied';
				inferenceCopyLabelTimer = setTimeout(() => {
					label.textContent = 'Copy serve command';
					inferenceCopyLabelTimer = null;
				}, 1200);
			}
		});

		setActiveEngine(activeEngine);
	}

	initJetsonInferenceMatrix();
	document.addEventListener('astro:page-load', initJetsonInferenceMatrix);
</script>
