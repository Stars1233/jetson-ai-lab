---
import type { InferenceCategory } from '../lib/engines';
import { enginesForCategory, defaultEngineForCategory } from '../lib/engines';
import { sortEnginesForUi } from '../lib/modelFrontmatterAdapter';
import {
	applyMatrixModuleDisabledFlags,
	buildCommandMatrix,
	buildModuleCommandMatrix,
	engineHasPlatformContent,
	engineSupportsModule,
	matchSupportedEngine,
	type SupportedEngineEntry,
	visibleModulesForEngines,
	moduleIdToPlatformMap,
} from '../lib/inferenceCommands';
import {
	evalMatrixModuleSpecs,
	evalModalShowsPython,
	evalModalShowsShell,
	evalSnippetByModule,
	oneShotHasRunModalContent,
	type OneShotForRunModal,
} from '../lib/evalRunModal';
import JetsonEngineRail from './matrix/JetsonEngineRail.astro';
import JetsonModuleTabBar from './matrix/JetsonModuleTabBar.astro';
import type { MatrixModuleTabItem } from './matrix/panelTypes';

interface SupportedEngine {
	engine: string;
	type?: string;
	install_command?: string;
	run_command?: string;
	install_command_orin?: string;
	serve_command_orin?: string;
	install_command_thor?: string;
	serve_command_thor?: string;
	run_command_orin?: string;
	run_command_thor?: string;
	modules_supported?: string[];
	run_commands_by_module?: Record<string, string>;
}

interface Props {
	modelId: string;
	modelName: string;
	category: InferenceCategory;
	forceModal?: boolean;
    hfCheckpoint?: string;
    supportedEngines?: SupportedEngine[];
    /** From model `matrix_modules_disabled` when rendering from catalog */
    matrixModulesDisabled?: string[];
	/** `one_shot_inference` — Run modal shows eval matrix when no serve matrix */
	oneShotInference?: OneShotForRunModal | null;
}

const {
	modelId,
	modelName,
	category,
	forceModal = false,
	hfCheckpoint,
    supportedEngines,
    matrixModulesDisabled,
	oneShotInference = null,
} = Astro.props as Props;

let engines = enginesForCategory(category);

// Filter engines if supportedEngines is provided
if (supportedEngines && supportedEngines.length > 0) {
    const supportedIds = supportedEngines.map(e => e.engine.toLowerCase());
    // Map markdown engine names (e.g., "Ollama", "vLLM") to engine IDs (e.g., "ollama", "vllm")
    // Special handling for vLLM if needed, but toLowerCase usually works if IDs are lowercase
    engines = engines.filter(e => supportedIds.includes(e.id) || supportedIds.includes(e.label.toLowerCase()));
    
    // If filtering resulted in empty list (mismatch), fall back to all category engines or handle error
    if (engines.length === 0) {
        // Fallback: try to find engines that match loosely
         const allEngines = enginesForCategory(category);
         engines = allEngines.filter(e => supportedIds.some(id => id.includes(e.id) || e.id.includes(id)));
    }
    const sortedYaml = sortEnginesForUi(supportedEngines as SupportedEngineEntry[]);
    const rank = new Map<string, number>();
    sortedYaml.forEach((se, i) => {
      const k = se.engine.toLowerCase().replace(/[.\-_]/g, '');
      rank.set(k, i);
    });
    engines = [...engines].sort((a, b) => {
      const ka = a.id.replace(/[.\-_]/g, '');
      const kb = b.id.replace(/[.\-_]/g, '');
      return (rank.get(ka) ?? 99) - (rank.get(kb) ?? 99);
    });
}

const defaultEngine = defaultEngineForCategory(category);
let defaultEngineId = defaultEngine?.id || (engines[0]?.id ?? '');

const buttonId = `run-btn-${modelId}`;
const modalId = `run-modal-${modelId}`;

// Determine which devices are supported based on run commands
const allDevices = ['Jetson Orin', 'Jetson Thor'];
let jetsonDevices = allDevices;

if (supportedEngines && supportedEngines.length > 0) {
    const hasOrin = supportedEngines.some(e => engineHasPlatformContent(e, 'orin'));
    const hasThor = supportedEngines.some(e => engineHasPlatformContent(e, 'thor'));
    
    const availableDevices: string[] = [];
    if (hasOrin) availableDevices.push('Jetson Orin');
    if (hasThor) availableDevices.push('Jetson Thor');
    
    if (availableDevices.length > 0) {
        jetsonDevices = availableDevices;
    }
}

const jetpacks = ['6.1+', '6.0', '5.1'];

const needsHfToken =
	supportedEngines?.some((e) => {
		const cmds = [
			e.serve_command_orin,
			e.serve_command_thor,
			e.run_command_orin,
			e.run_command_thor,
			e.run_command,
		];
		return cmds.some((c) => c && c.includes('HF_TOKEN'));
	}) ?? false;

const engineUi = engines.map((e) => {
	const entry = supportedEngines?.length ? matchSupportedEngine(supportedEngines, e.id) : undefined;
	const type = entry?.type?.trim() ?? '';
	return { id: e.id, label: e.label, type };
});

const commandMatrix = buildCommandMatrix(category, supportedEngines);
const visibleModules = supportedEngines?.length
	? applyMatrixModuleDisabledFlags(visibleModulesForEngines(supportedEngines), matrixModulesDisabled)
	: [];
const useServeMatrix = visibleModules.length > 0 && engines.length > 0;
const evalModuleSpecs = oneShotInference ? evalMatrixModuleSpecs(oneShotInference) : [];
const useEvalMatrix =
	!useServeMatrix &&
	oneShotHasRunModalContent(oneShotInference) &&
	evalModuleSpecs.length > 0;
const evalSnippetMap = useEvalMatrix && oneShotInference
	? evalSnippetByModule(
			oneShotInference,
			evalModuleSpecs.map((m) => m.id)
		)
	: {};
const evalShowShell = useEvalMatrix ? evalModalShowsShell(evalSnippetMap) : false;
const evalShowPython = useEvalMatrix ? evalModalShowsPython(evalSnippetMap) : false;

/** Legacy Layout meta: serve matrix flag */
const useMatrix = useServeMatrix;
const moduleCommandMatrix = useServeMatrix
	? buildModuleCommandMatrix(category, supportedEngines)
	: {};
const moduleIdToPlatform = useServeMatrix
	? moduleIdToPlatformMap(visibleModules)
	: useEvalMatrix
		? moduleIdToPlatformMap(evalModuleSpecs)
		: {};

if (useServeMatrix && engines.length > 0) {
	defaultEngineId = engines[0].id;
}

const defaultEngineEntry =
	supportedEngines?.length && defaultEngineId
		? matchSupportedEngine(supportedEngines, defaultEngineId)
		: undefined;

function moduleTabOkForMatrixEngine(m: (typeof visibleModules)[0]): boolean {
	if (m.disabled === true) return false;
	if (!defaultEngineEntry) return true;
	return engineSupportsModule(defaultEngineEntry, m.id);
}

const modalVisibleModules = visibleModules.map((m) => ({
	id: m.id,
	shortLabel: m.shortLabel,
	label: m.label,
	disabled: m.disabled === true,
	tabKicker: m.tabKicker,
	tabTitleBold: m.tabTitleBold,
	tabSubtitleGray: m.tabSubtitleGray,
	iconSrc: m.iconSrc,
	iconBadgeFamily: m.iconBadgeFamily,
	iconBadgeMemory: m.iconBadgeMemory,
}));

function runModalModuleTabDisabled(mod: (typeof modalVisibleModules)[0]): boolean {
	if (mod.disabled) return true;
	if (!defaultEngineEntry) return false;
	return !engineSupportsModule(defaultEngineEntry, mod.id);
}

const _runFirstEnIdx = visibleModules.findIndex((m) => moduleTabOkForMatrixEngine(m));
const firstEnabledRunModuleIndex = _runFirstEnIdx >= 0 ? _runFirstEnIdx : 0;
const defaultModuleId =
	visibleModules.find((m) => moduleTabOkForMatrixEngine(m))?.id ?? visibleModules[0]?.id ?? '';

const evalModalVisibleModules = evalModuleSpecs.map((m) => ({
	id: m.id,
	shortLabel: m.shortLabel,
	label: m.label,
	disabled: false as boolean,
	tabKicker: m.tabKicker,
	tabTitleBold: m.tabTitleBold,
	tabSubtitleGray: m.tabSubtitleGray,
	iconSrc: m.iconSrc,
	iconBadgeFamily: m.iconBadgeFamily,
	iconBadgeMemory: m.iconBadgeMemory,
}));
const defaultEvalModuleId = evalModuleSpecs[0]?.id ?? '';
const firstEvalModuleTabIndex = Math.max(
	0,
	evalModalVisibleModules.findIndex((m) => m.id === defaultEvalModuleId)
);

const runModalModuleItemsServe: MatrixModuleTabItem[] = modalVisibleModules.map((m) => ({
	id: m.id,
	label: m.label,
	tabKicker: m.tabKicker,
	tabTitleBold: m.tabTitleBold,
	tabSubtitleGray: m.tabSubtitleGray,
	iconSrc: m.iconSrc,
	iconBadgeFamily: m.iconBadgeFamily,
	iconBadgeMemory: m.iconBadgeMemory,
	globalDisabled: m.disabled,
}));
const runModalTabDisabledServe = modalVisibleModules.map((m) => runModalModuleTabDisabled(m));

const runModalModuleItemsEval: MatrixModuleTabItem[] = evalModalVisibleModules.map((m) => ({
	id: m.id,
	label: m.label,
	tabKicker: m.tabKicker,
	tabTitleBold: m.tabTitleBold,
	tabSubtitleGray: m.tabSubtitleGray,
	iconSrc: m.iconSrc,
	iconBadgeFamily: m.iconBadgeFamily,
	iconBadgeMemory: m.iconBadgeMemory,
	globalDisabled: false,
}));
const runModalTabDisabledEval = evalModalVisibleModules.map(() => false);

const runModalEngineRailRows = engineUi.map((e) => ({
	key: e.id,
	title: e.label,
	subtitle: e.type?.trim() ? e.type : undefined,
}));

const modulesSupportedByEngine: Record<string, string[] | null> = {};
if (supportedEngines?.length) {
	for (const ui of engines) {
		const entry = matchSupportedEngine(supportedEngines, ui.id);
		if (!entry) {
			modulesSupportedByEngine[ui.id] = null;
			continue;
		}
		const ms = entry.modules_supported;
		if (ms === undefined) modulesSupportedByEngine[ui.id] = null;
		else if (ms.length === 0) modulesSupportedByEngine[ui.id] = [];
		else modulesSupportedByEngine[ui.id] = [...ms];
	}
}

// Build device-specific engine images from supportedEngines
const engineImagesOrin: Record<string, string> = {
	ollama: 'ollama/ollama:latest',
	vllm: 'ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin',
	llamacpp: 'ghcr.io/nvidia-ai-iot/llama_cpp:latest-jetson-orin',
	tensorrtllm: 'nvcr.io/nvidia/tensorrt-llm:latest',
	diffusers: 'pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime',
	comfyui: 'ghcr.io/comfyanonymous/comfyui:latest',
	whispercpp: 'ghcr.io/ggerganov/whisper.cpp:latest',
	riva: 'nvcr.io/nvidia/riva/riva-speech:latest'
};

const engineImagesThor: Record<string, string> = {
	ollama: 'ollama/ollama:latest',
	vllm: 'ghcr.io/nvidia-ai-iot/vllm:latest-jetson-thor',
	llamacpp: 'ghcr.io/nvidia-ai-iot/llama_cpp:latest-jetson-thor',
	tensorrtllm: 'nvcr.io/nvidia/tensorrt-llm:latest',
	diffusers: 'pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime',
	comfyui: 'ghcr.io/comfyanonymous/comfyui:latest',
	whispercpp: 'ghcr.io/ggerganov/whisper.cpp:latest',
	riva: 'nvcr.io/nvidia/riva/riva-speech:latest'
};

// Legacy fallback (for backward compatibility)
const engineImages = engineImagesOrin;
---

<button id={buttonId} data-run-open={modelId} class="px-3 py-1.5 rounded-md bg-nvidia-black text-nvidia-white hover:bg-nvidia-green hover:text-nvidia-black transition-colors text-xs font-bold">
	Run
	<span class="sr-only">Run {modelName}</span>
</button>

<div
	id={modalId}
	data-run-modal={modelId}
	class="hidden fixed inset-0 z-[60] text-left"
	data-active-module={useServeMatrix ? defaultModuleId : useEvalMatrix ? defaultEvalModuleId : ''}
	data-active-engine={useServeMatrix ? defaultEngineId : ''}
	data-meta={JSON.stringify({
		engineUi,
		engineImages,
		engineImagesOrin,
		engineImagesThor,
		jetsonDevices,
		jetpacks,
		defaultEngineId,
		defaultModuleId,
		defaultEvalModuleId,
		category,
		modelId,
		modelName,
		hfCheckpoint,
		supportedEngines,
		needsHfToken,
		commandMatrix,
		useMatrix,
		useEvalMatrix,
		moduleCommandMatrix,
		modalVisibleModules,
		evalModalVisibleModules,
		evalSnippetByModule: evalSnippetMap,
		evalShowShell,
		evalShowPython,
		moduleIdToPlatform,
		modulesSupportedByEngine,
	})}
>
	<div data-overlay data-run-overlay class="absolute inset-0 backdrop-blur-sm transition-opacity" style="background-color: rgba(0, 0, 0, 0.4);"></div>
	
    <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-6 pointer-events-none">
        <div class:list={['w-full min-w-0 bg-white rounded-xl shadow-2xl pointer-events-auto flex flex-col max-h-[90vh] overflow-hidden border border-nvidia-gray-100', (useServeMatrix || useEvalMatrix) ? 'max-w-7xl' : 'max-w-5xl']}>
            
            <!-- Header -->
            <div class="px-6 py-5 border-b border-nvidia-gray-100 flex items-center justify-between bg-white shrink-0">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-lg bg-nvidia-green/10 text-nvidia-green flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-nvidia-black leading-none mb-1">{modelName}</h3>
                        <p class="text-sm text-nvidia-gray-500">
							{useServeMatrix ? 'Quick Start Runner' : useEvalMatrix ? 'One-shot inference / evaluation' : 'Quick Start Runner'}
						</p>
                    </div>
                </div>
                <button data-close data-run-close class="text-nvidia-gray-400 hover:text-nvidia-black hover:bg-nvidia-gray-50 p-2 rounded-lg transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            {useServeMatrix && (
                <JetsonModuleTabBar
                    variant="run-modal"
                    modules={runModalModuleItemsServe}
                    tabDisabled={runModalTabDisabledServe}
                    firstEnabledIndex={firstEnabledRunModuleIndex}
                />
            )}

            {useEvalMatrix && (
                <JetsonModuleTabBar
                    variant="run-modal"
                    modules={runModalModuleItemsEval}
                    tabDisabled={runModalTabDisabledEval}
                    firstEnabledIndex={firstEvalModuleTabIndex}
                    applyIconGroupTint={false}
                />
            )}

            {useEvalMatrix && oneShotInference?.intro?.trim() && (
                <p class="px-6 py-3 text-sm text-nvidia-gray-600 border-b border-nvidia-gray-100 bg-white shrink-0">
                    {oneShotInference.intro.trim()}
                </p>
            )}

            <!-- Content -->
            <div class="flex-1 flex flex-col min-h-0 overflow-hidden">
                {useServeMatrix ? (
                <div class="flex-1 flex flex-col min-h-0 overflow-hidden">
                    <div class="flex flex-1 min-h-0 flex-col lg:flex-row overflow-hidden">
                        <div class="p-4 sm:p-6 overflow-y-auto bg-white border-b lg:border-b-0 lg:border-r border-nvidia-gray-100 shrink-0 w-full lg:w-1/5 lg:min-w-[11rem] lg:max-w-[16rem]">
                            <section>
                                <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-2">Inference Engine</h4>
                                <JetsonEngineRail variant="run-modal" engines={runModalEngineRailRows} />
                            </section>
                        </div>
                        <div class="bg-nvidia-gray-50 flex flex-col min-w-0 min-h-0 flex-1 overflow-hidden p-3 sm:p-4">
                            <div class="flex items-center justify-start mb-4 shrink-0 gap-2 min-w-0">
                                <div class="flex bg-white rounded-lg p-1 shadow-sm border border-nvidia-gray-200">
                                    {['shell'].map((tab, idx) => (
                                        <button
                                            class={`px-4 py-1.5 rounded-md text-xs font-bold transition-all ${idx===0 ? 'bg-nvidia-black text-nvidia-white shadow-sm' : 'text-nvidia-gray-600 hover:text-nvidia-black hover:bg-nvidia-gray-50'}`}
                                            data-tab={tab}
                                        >
                                            {tab.charAt(0).toUpperCase() + tab.slice(1)}
                                        </button>
                                    ))}
                                </div>
                            </div>
                            <div class="flex-1 relative group min-h-[120px] min-w-0 max-w-full rounded-xl border border-slate-800 shadow-lg bg-slate-900 overflow-hidden">
                                <button
                                    type="button"
                                    data-copy
                                    data-run-copy
                                    data-run-copy-reset-label="Copy serve command"
                                    class="absolute top-2 right-2 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/65 backdrop-blur-sm border border-white/40 text-nvidia-gray-800 hover:bg-white/80 hover:border-nvidia-green/60 hover:text-nvidia-green transition-all shadow-md text-xs font-bold"
                                >
                                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                    </svg>
                                    <span data-run-copy-label>Copy serve command</span>
                                </button>
                                <pre class="h-full max-h-[min(42vh,380px)] min-w-0 w-full max-w-full p-4 sm:p-5 text-left text-sm font-mono leading-relaxed overflow-x-hidden overflow-y-auto text-slate-200 scrollbar-thin scrollbar-thumb-slate-700 scrollbar-track-transparent whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><code data-snippet class="block w-full max-w-full text-left">Loading command...</code></pre>
                            </div>
                            <p class="mt-3 text-[10px] text-center text-nvidia-gray-500 shrink-0">
                                Commands are auto-generated based on your configuration settings.
                            </p>
                        </div>
                    </div>
                    <div
                        data-run-matrix-advanced-strip
                        data-run-advanced-scope
                        class="hidden w-full shrink-0 bg-white border-t border-nvidia-gray-100 px-4 sm:px-6 py-3 max-h-[min(48vh,320px)] overflow-y-auto"
                    >
                        <div class="flex items-center justify-between gap-2">
                            <h4 class="text-[10px] font-bold text-nvidia-gray-400 uppercase tracking-wider">Advanced configuration</h4>
                            <button type="button" data-advanced-toggle data-run-advanced-toggle class="text-xs font-medium text-nvidia-green hover:text-nvidia-green/80 flex items-center gap-1 shrink-0">
                                <span data-toggle-text>Show Advanced</span>
                                <svg data-toggle-icon class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                        </div>
                        <div data-advanced class="hidden space-y-4 mt-4">
                            <section data-hf-token-section class="hidden pb-4 border-b border-nvidia-gray-100 last:border-0 last:mb-0 last:pb-0">
                                <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-3">Authentication</h4>
                                <div>
                                    <label class="block text-sm font-medium text-nvidia-gray-700 mb-1.5">
                                        Hugging Face Token
                                        <span class="text-red-500 ml-0.5">*</span>
                                    </label>
                                    <input data-hf-token type="text" placeholder="hf_..." class="w-full max-w-xl bg-nvidia-gray-50 border border-nvidia-gray-200 text-nvidia-black text-sm rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none transition-all placeholder:text-nvidia-gray-300 font-mono text-xs" />
                                    <p class="text-[10px] text-nvidia-gray-400 mt-1.5">This model requires a <a href="https://huggingface.co/settings/tokens" target="_blank" class="text-nvidia-green hover:underline">Hugging Face access token</a>. The token is inserted into the command and never stored.</p>
                                </div>
                            </section>
                            <section data-vllm-config class="hidden">
                                <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-3">vLLM Configuration</h4>
                                <p class="text-xs text-nvidia-gray-500 mb-3">
                                    Configure vLLM server parameters. Leave empty to use defaults.
                                </p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                            Port
                                            <span class="text-nvidia-gray-400 font-normal ml-1">(--port)</span>
                                        </label>
                                        <input data-vllm-port type="number" min="1024" max="65535" placeholder="8000" class="w-full bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                            Max Model Length
                                            <span class="text-nvidia-gray-400 font-normal ml-1">(--max-model-len)</span>
                                        </label>
                                        <input data-vllm-max-model-len type="number" min="512" max="131072" step="512" placeholder="32000" class="w-full bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                        <p class="text-[10px] text-nvidia-gray-400 mt-1">Maximum context length the model can handle</p>
                                    </div>
                                    <div class="sm:col-span-2">
                                        <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                            GPU Memory Utilization
                                            <span class="text-nvidia-gray-400 font-normal ml-1">(--gpu-memory-utilization)</span>
                                        </label>
                                        <input data-vllm-gpu-mem type="number" min="0.1" max="1.0" step="0.05" placeholder="0.9" class="w-full sm:max-w-xs bg-white border border-nvidia-gray-200 rounded-lg px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                        <p class="text-[10px] text-nvidia-gray-400 mt-1">Fraction of GPU memory to use (0.1 - 1.0)</p>
                                    </div>
                                </div>
                                <div class="pt-1">
                                    <button type="button" data-vllm-reset class="text-xs text-nvidia-gray-500 hover:text-nvidia-black underline decoration-dotted">Reset to defaults</button>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
                ) : useEvalMatrix ? (
                <div class="flex-1 flex flex-col min-h-0 overflow-hidden">
                    <div class="bg-nvidia-gray-50 flex flex-col min-w-0 min-h-0 flex-1 overflow-hidden p-3 sm:p-4">
                        <div class="flex items-center justify-start mb-4 shrink-0 gap-2 min-w-0">
                            <div class="flex bg-white rounded-lg p-1 shadow-sm border border-nvidia-gray-200">
                                {evalShowShell && (
                                    <button
                                        type="button"
                                        data-tab="shell"
                                        class:list={[
                                            'px-4 py-1.5 rounded-md text-xs font-bold transition-all',
                                            evalShowPython
                                                ? 'bg-nvidia-black text-nvidia-white shadow-sm'
                                                : 'bg-nvidia-black text-nvidia-white shadow-sm',
                                        ]}
                                    >
                                        Shell
                                    </button>
                                )}
                                {evalShowPython && (
                                    <button
                                        type="button"
                                        data-tab="python"
                                        class:list={[
                                            'px-4 py-1.5 rounded-md text-xs font-bold transition-all',
                                            evalShowShell
                                                ? 'text-nvidia-gray-600 hover:text-nvidia-black hover:bg-nvidia-gray-50'
                                                : 'bg-nvidia-black text-nvidia-white shadow-sm',
                                        ]}
                                    >
                                        Python
                                    </button>
                                )}
                            </div>
                        </div>
                        <div class="flex-1 relative group min-h-[120px] min-w-0 max-w-full rounded-xl border border-slate-800 shadow-lg bg-slate-900 overflow-hidden">
                            <button
                                type="button"
                                data-copy
                                data-run-copy
                                data-run-copy-reset-label="Copy inference command"
                                class="absolute top-2 right-2 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/65 backdrop-blur-sm border border-white/40 text-nvidia-gray-800 hover:bg-white/80 hover:border-nvidia-green/60 hover:text-nvidia-green transition-all shadow-md text-xs font-bold"
                            >
                                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                </svg>
                                <span data-run-copy-label>Copy inference command</span>
                            </button>
                            <pre class="h-full max-h-[min(42vh,380px)] min-w-0 w-full max-w-full p-4 sm:p-5 text-left text-sm font-mono leading-relaxed overflow-x-hidden overflow-y-auto text-slate-200 scrollbar-thin scrollbar-thumb-slate-700 scrollbar-track-transparent whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><code data-snippet class="block w-full max-w-full text-left">Loading command...</code></pre>
                        </div>
                        <p class="mt-3 text-[10px] text-center text-nvidia-gray-500 shrink-0">
                            One-shot / eval commands for the selected module (not a long-running server).
                        </p>
                    </div>
                </div>
                ) : (
                <div class="flex-1 flex flex-col lg:flex-row min-h-0 overflow-hidden">
                    <div class="p-4 sm:p-6 overflow-y-auto bg-white border-b lg:border-b-0 lg:border-r border-nvidia-gray-100 shrink-0 w-full lg:w-5/12">
                        <div class="space-y-6">
                            <section>
                                <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-4">Target Environment</h4>
                                <div class="space-y-4">
                                    <div class="group">
                                        <label class="block text-sm font-medium text-nvidia-gray-700 mb-1.5">Jetson Device</label>
                                        <div class="relative">
                                            <select data-device class="w-full appearance-none bg-nvidia-gray-50 border border-nvidia-gray-200 text-nvidia-black text-sm rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none transition-all">
                                                {jetsonDevices.map(d => (<option>{d}</option>))}
                                            </select>
                                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-nvidia-gray-500">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="group">
                                        <label class="block text-sm font-medium text-nvidia-gray-700 mb-1.5">Inference Engine</label>
                                        <div class="relative">
                                            <select data-engine class="w-full appearance-none bg-nvidia-gray-50 border border-nvidia-gray-200 text-nvidia-black text-sm rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none transition-all">
                                                {engineUi.map(e => (
                                                    <option value={e.id} selected={e.id === defaultEngineId}>
                                                        {e.type ? `${e.label} (${e.type})` : e.label}
                                                    </option>
                                                ))}
                                            </select>
                                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-nvidia-gray-500">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>
                            <div data-run-legacy-advanced data-run-advanced-scope class="hidden pt-4 border-t border-nvidia-gray-100">
                                <div class="flex items-center justify-between gap-2 mb-0">
                                    <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider">Advanced configuration</h4>
                                    <button type="button" data-advanced-toggle data-run-advanced-toggle class="text-xs font-medium text-nvidia-green hover:text-nvidia-green/80 flex items-center gap-1 shrink-0">
                                        <span data-toggle-text>Show Advanced</span>
                                        <svg data-toggle-icon class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </button>
                                </div>
                                <div data-advanced class="hidden space-y-6 mt-4">
                                    <section data-hf-token-section class="hidden">
                                        <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-4">Authentication</h4>
                                        <div>
                                            <label class="block text-sm font-medium text-nvidia-gray-700 mb-1.5">
                                                Hugging Face Token
                                                <span class="text-red-500 ml-0.5">*</span>
                                            </label>
                                            <input data-hf-token type="text" placeholder="hf_..." class="w-full bg-nvidia-gray-50 border border-nvidia-gray-200 text-nvidia-black text-sm rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-nvidia-green/20 focus:border-nvidia-green outline-none transition-all placeholder:text-nvidia-gray-300 font-mono text-xs" />
                                            <p class="text-[10px] text-nvidia-gray-400 mt-1.5">This model requires a <a href="https://huggingface.co/settings/tokens" target="_blank" class="text-nvidia-green hover:underline">Hugging Face access token</a>. The token is inserted into the command and never stored.</p>
                                        </div>
                                    </section>
                                    <section data-vllm-config class="hidden">
                                        <h4 class="text-xs font-bold text-nvidia-gray-400 uppercase tracking-wider mb-3">vLLM Configuration</h4>
                                        <p class="text-xs text-nvidia-gray-500 mb-3">
                                            Configure vLLM server parameters. Leave empty to use defaults.
                                        </p>
                                        <div>
                                            <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                                Port
                                                <span class="text-nvidia-gray-400 font-normal ml-1">(--port)</span>
                                            </label>
                                            <input data-vllm-port type="number" min="1024" max="65535" placeholder="8000" class="w-full bg-white border border-nvidia-gray-200 rounded px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                                Max Model Length
                                                <span class="text-nvidia-gray-400 font-normal ml-1">(--max-model-len)</span>
                                            </label>
                                            <input data-vllm-max-model-len type="number" min="512" max="131072" step="512" placeholder="32000" class="w-full bg-white border border-nvidia-gray-200 rounded px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                            <p class="text-[10px] text-nvidia-gray-400 mt-1">Maximum context length the model can handle</p>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-nvidia-gray-600 mb-1">
                                                GPU Memory Utilization
                                                <span class="text-nvidia-gray-400 font-normal ml-1">(--gpu-memory-utilization)</span>
                                            </label>
                                            <input data-vllm-gpu-mem type="number" min="0.1" max="1.0" step="0.05" placeholder="0.9" class="w-full bg-white border border-nvidia-gray-200 rounded px-2 py-1.5 text-sm focus:border-nvidia-green focus:ring-1 focus:ring-nvidia-green outline-none placeholder:text-nvidia-gray-300" />
                                            <p class="text-[10px] text-nvidia-gray-400 mt-1">Fraction of GPU memory to use (0.1 - 1.0)</p>
                                        </div>
                                        <div class="pt-2">
                                            <button type="button" data-vllm-reset class="text-xs text-nvidia-gray-500 hover:text-nvidia-black underline decoration-dotted">Reset to defaults</button>
                                        </div>
                                    </section>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-nvidia-gray-50 flex flex-col min-w-0 min-h-0 overflow-hidden w-full lg:w-7/12 p-6 h-full">
                        <div class="flex items-center justify-start mb-4 shrink-0 gap-2 min-w-0">
                            <div class="flex bg-white rounded-lg p-1 shadow-sm border border-nvidia-gray-200">
                                {['shell'].map((tab, idx) => (
                                    <button
                                        class={`px-4 py-1.5 rounded-md text-xs font-bold transition-all ${idx===0 ? 'bg-nvidia-black text-nvidia-white shadow-sm' : 'text-nvidia-gray-600 hover:text-nvidia-black hover:bg-nvidia-gray-50'}`}
                                        data-tab={tab}
                                    >
                                        {tab.charAt(0).toUpperCase() + tab.slice(1)}
                                    </button>
                                ))}
                            </div>
                        </div>
                        <div class="flex-1 relative group min-h-[120px] min-w-0 max-w-full rounded-xl border border-slate-800 shadow-lg bg-slate-900 overflow-hidden">
                            <button
                                type="button"
                                data-copy
                                data-run-copy
                                data-run-copy-reset-label="Copy serve command"
                                class="absolute top-2 right-2 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/65 backdrop-blur-sm border border-white/40 text-nvidia-gray-800 hover:bg-white/80 hover:border-nvidia-green/60 hover:text-nvidia-green transition-all shadow-md text-xs font-bold"
                            >
                                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                </svg>
                                <span data-run-copy-label>Copy serve command</span>
                            </button>
                            <pre class="h-full max-h-[min(50vh,420px)] min-w-0 w-full max-w-full p-4 sm:p-5 text-left text-sm font-mono leading-relaxed overflow-x-hidden overflow-y-auto text-slate-200 scrollbar-thin scrollbar-thumb-slate-700 scrollbar-track-transparent whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><code data-snippet class="block w-full max-w-full text-left">Loading command...</code></pre>
                        </div>
                        <p class="mt-3 text-[10px] text-center text-nvidia-gray-500">
                            Commands are auto-generated based on your configuration settings.
                        </p>
                    </div>
                </div>
                )}
            </div>
        </div>
    </div>
</div>

<style is:global>
	.run-modal-engine-bar {
		overflow-y: hidden;
	}
</style>
